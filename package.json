{
  "name": "brumoutloud-site",
  "version": "1.0.0",
  "scripts": {
    "build:css": "npx tailwindcss build -o css/tailwind.css",
    "build:venues": "node build-venues-ssg.js",
    "build:venues:simple": "node build-venues-simple.js",
    "build:events": "node build-events-ssg.js",
    "build:events-listing": "node build-events-listing-api.js",
    "build:venues-listing": "node build-venues-listing-api.js",
    "generate-sitemap": "node generate-comprehensive-sitemap.js",
    "build:remotion": "cd remotion-templates && npm run build",
    "dev:remotion": "cd remotion-templates && npm run dev",
    "render:reel": "cd remotion-templates && npm run render",
    "optimize:css": "node optimize-css.js",
    "optimize:critical": "node create-critical-css.js",
    "optimize:all": "npm run optimize:css && npm run optimize:critical",
    "build": "npm run optimize:all && npm run build:venues:simple && npm run build:events && npm run build:events-listing && npm run build:venues-listing && npm run generate-sitemap"
  },
  "dependencies": {
    "@remotion/bundler": "^4.0.330",
    "@remotion/cli": "^4.0.330",
    "@remotion/player": "^4.0.330",
    "@remotion/renderer": "^4.0.330",
    "airtable": "^0.12.2",
    "cheerio": "^1.0.0-rc.12",
    "cloudinary": "^1.41.3",
    "firebase": "^10.12.2",
    "firebase-admin": "^12.1.0",
    "formidable": "^3.5.1",
    "handlebars": "^4.7.8",
    "lambda-multipart-parser": "^1.0.1",
    "node-fetch": "^2.7.0",
    "parse-multipart": "^1.0.4",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "sharp": "^0.33.2",
    "uuid": "^9.0.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "firebase-tools": "^14.11.2",
    "netlify-cli": "^22.1.6",
    "tailwindcss": "^3.4.4",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=20.18.1"
  }
}
