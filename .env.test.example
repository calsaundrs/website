# Copy to .env.test and fill in values for a Firebase test admin user.
# .env.test is gitignored. Never commit real credentials.
#
# To create a test admin:
#   1. Firebase Console → Authentication → Add user
#   2. Use a dedicated email like admin-test@brumoutloud.co.uk
#   3. Grant the same Firestore rules access as a production admin

TEST_ADMIN_EMAIL=
TEST_ADMIN_PASSWORD=
