---
import PublicLayout from '../components/PublicLayout.astro';

const collectionPage = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'LGBTQ+ Events in Birmingham and the West Midlands',
  description:
    'Discover LGBTQ+ events in Birmingham and the West Midlands. Find drag shows, club nights, community meetups, and more.',
  url: 'https://brumoutloud.co.uk/events',
  breadcrumb: {
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://www.brumoutloud.co.uk/' },
      { '@type': 'ListItem', position: 2, name: 'Events', item: 'https://brumoutloud.co.uk/events' },
    ],
  },
};

const faqPage = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'What LGBTQ+ events are on in Birmingham this week?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: "Birmingham has LGBTQ+ events most nights of the week in the Gay Village. Regular nights include POUNDED at The Nightingale (Thursdays), Big Saturgay (Saturdays), Foxeoke karaoke at The Fox (Fridays), drag at The Village Inn, and cabaret at Eden Bar. This page lists every upcoming LGBTQ+ event and is updated daily.",
      },
    },
    {
      '@type': 'Question',
      name: 'Where are LGBTQ+ events held in Birmingham?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: "Most LGBTQ+ events in Birmingham take place in the Gay Village on Hurst Street, Southside. Key venues include The Nightingale Club (Kent Street), The Fox (Lower Essex Street), Missing Bar (Bromsgrove Street), Eden Bar (Gooch Street), The Village Inn (Kent Street) and Glamorous (Hurst Street).",
      },
    },
    {
      '@type': 'Question',
      name: 'Are there 18+ or adult LGBTQ+ events in Birmingham?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Yes. Some LGBTQ+ events in Birmingham are 18+ only or feature adult content. On this page, use the 18+ toggle to include adult events in the listings. These events are hidden by default.',
      },
    },
  ],
};
---
<PublicLayout
  title="LGBTQ+ Events Birmingham | Gay Village What's On | Brum Outloud"
  description="Find every LGBTQ+ event in Birmingham and the West Midlands — drag shows, club nights, Pride parties, and more. Updated daily."
  canonical="https://www.brumoutloud.co.uk/events"
  watermark="EVENTS"
  jsonLd={[collectionPage, faqPage]}
>
  <Fragment slot="head">
    <style>
      .filter-group { background: #111; padding: 4px; border-radius: 9999px; display: inline-flex; gap: 2px; border: 1px solid rgba(255,255,255,0.1); }
      .filter-pill { padding: 0.5rem 1.25rem; font-weight: 700; font-size: 0.8rem; text-transform: uppercase; letter-spacing: 0.05em; background: transparent; color: #888; border-radius: 9999px; cursor: pointer; transition: all 0.3s; white-space: nowrap; }
      .filter-pill:hover { color: white; background: rgba(255,255,255,0.05); }
      .filter-pill.active { background: #222; color: white; box-shadow: 0 2px 8px rgba(0,0,0,0.5); }

      .search-input-wrapper { position: relative; flex-grow: 1; max-width: 300px; }
      .search-input { width: 100%; background: #111; border: 1px solid rgba(255,255,255,0.1); color: white; padding: 0.6rem 1rem 0.6rem 2.5rem; border-radius: 9999px; font-size: 0.875rem; transition: all 0.2s; }
      .search-input:focus { outline: none; border-color: var(--color-purple); box-shadow: 0 0 0 2px rgba(155,93,229,0.2); }
      .search-icon { position: absolute; left: 1rem; top: 50%; transform: translateY(-50%); color: #666; transition: color 0.2s; }
      .search-input:focus + .search-icon { color: var(--color-purple); }

      .nsfw-toggle { display: flex; align-items: center; gap: 0.625rem; cursor: pointer; background: none; border: 3px solid #444; padding: 0.4rem 1rem 0.4rem 0.5rem; transition: all 0.2s; }
      .nsfw-toggle:hover { border-color: var(--color-pink); }
      .nsfw-toggle[aria-pressed="true"] { border-color: var(--color-pink); background: rgba(232,58,153,0.15); }
      .nsfw-toggle-track { position: relative; width: 2.5rem; height: 1.375rem; background: #333; border: 2px solid #555; display: block; transition: all 0.2s; }
      .nsfw-toggle[aria-pressed="true"] .nsfw-toggle-track { background: var(--color-pink); border-color: var(--color-pink); }
      .nsfw-toggle-thumb { position: absolute; top: 2px; left: 2px; width: 0.875rem; height: 0.875rem; background: #888; display: block; transition: all 0.2s; }
      .nsfw-toggle[aria-pressed="true"] .nsfw-toggle-thumb { left: calc(100% - 1rem); background: white; }
      .nsfw-toggle-label { font-weight: 800; font-size: 0.8rem; text-transform: uppercase; letter-spacing: 0.1em; color: #666; font-family: 'Syne', sans-serif; transition: color 0.2s; }
      .nsfw-toggle[aria-pressed="true"] .nsfw-toggle-label { color: var(--color-pink); }

      .event-card img { width: 100%; aspect-ratio: 4/3; object-fit: cover; display: block; background: #111; }
      .event-card .card-body { padding: 1rem 1.25rem 1.25rem; }

      .event-placeholder { width: 100%; aspect-ratio: 4/3; background: linear-gradient(135deg, #1a0a2e 0%, #0D0115 100%); display: flex; align-items: center; justify-content: center; }
      .event-placeholder i { font-size: 3rem; color: #333; }

      .skeleton-card { border: 2px solid #1E1E1E; background: #0A0A0A; border-radius: 0.5rem; overflow: hidden; }
      .skeleton-img { width: 100%; aspect-ratio: 4/3; background: linear-gradient(90deg, #111 25%, #1a1a1a 50%, #111 75%); background-size: 200% 100%; animation: shimmer 1.5s infinite; }
      .skeleton-text { height: 1rem; background: #1a1a1a; border-radius: 4px; animation: shimmer 1.5s infinite; }
      @keyframes shimmer { 0% { background-position: 200% 0; } 100% { background-position: -200% 0; } }
    </style>
  </Fragment>

  <section class="max-w-6xl mx-auto px-6 md:px-12 pt-10 pb-6 relative z-10">
    <div class="sticker bg-[var(--color-pink)] text-white text-sm mb-6 inline-block transform -rotate-2 uppercase tracking-widest font-black">24/7 SCENE</div>
    <h1 class="text-[clamp(4rem,10vw,8.5rem)] font-black text-white uppercase font-display misprint leading-[0.85] mb-8 shadow-glow">
      What's <br><span class="text-[var(--color-toxic)]">On.</span>
    </h1>
    <p class="text-xl md:text-2xl font-bold text-white opacity-90 max-w-xl italic">Your complete guide to LGBTQ+ events in Birmingham. From high-energy nights in the village to community gatherings.</p>
  </section>

  <section class="max-w-6xl mx-auto px-6 md:px-12 pb-8 sticky top-[84px] md:top-[92px] z-40 bg-[var(--color-bg)]/90 backdrop-blur py-4 border-b border-white/5 -mx-6 md:mx-auto md:-mx-12 mb-8">
    <div class="px-6 md:px-12 max-w-6xl mx-auto">
      <div class="flex flex-col md:flex-row md:items-center justify-between gap-6">
        <div class="flex flex-wrap gap-4 items-center flex-grow">
          <div class="filter-group">
            <button class="filter-pill date-filter active focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-white" data-filter="all">All</button>
            <button class="filter-pill date-filter focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-white" data-filter="today">Today</button>
            <button class="filter-pill date-filter focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-white" data-filter="this-week">This Week</button>
            <button class="filter-pill date-filter focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-white" data-filter="this-weekend">This Weekend</button>
            <button class="filter-pill date-filter focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-white" data-filter="this-month">This Month</button>
          </div>
          <div class="search-input-wrapper">
            <input type="text" id="event-search" class="search-input" placeholder="Search events, venues, DJs..." aria-label="Search events">
            <i class="fas fa-search search-icon"></i>
          </div>
        </div>
        <div class="flex items-center">
          <button id="nsfw-toggle" class="nsfw-toggle rounded-full focus-visible:outline-none focus-visible:ring-4 focus-visible:ring-[var(--color-toxic)]" aria-pressed="false">
            <span class="nsfw-toggle-track rounded-full"><span class="nsfw-toggle-thumb rounded-full"></span></span>
            <span class="nsfw-toggle-label pr-1">18+</span>
          </button>
        </div>
      </div>
      <p id="event-count" class="text-gray-400 text-xs font-bold uppercase tracking-widest mt-6"></p>
    </div>
  </section>

  <main class="max-w-6xl mx-auto px-6 md:px-12 pb-20 pt-4">
    <div id="pride-banner" class="hidden mb-12 rounded-lg overflow-hidden group focus-within:ring-4 focus-within:ring-[var(--color-pink)] transition-shadow" style="border: 2px solid transparent; background: linear-gradient(#000,#000) padding-box, linear-gradient(90deg,#e40303,#ff8c00,#ffed00,#008026,#004dff,#750787) border-box;">
      <a href="/birmingham-pride" class="flex items-center gap-5 px-6 py-5 focus:outline-none">
        <span class="text-4xl group-hover:scale-110 transition-transform duration-300">🏳️‍🌈</span>
        <div>
          <p class="font-black text-white uppercase text-lg font-display leading-tight group-hover:text-[var(--color-pink)] transition-colors">Birmingham Pride 2026 — 22–24 May</p>
          <p class="text-sm font-medium mt-1 text-gray-300 group-hover:text-white transition-colors">Events marked below are part of Pride weekend. <span class="underline decoration-2 underline-offset-4">See the full Birmingham Pride 2026 guide</span> →</p>
        </div>
      </a>
    </div>
    <div id="event-grid" class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-6 md:gap-8">
      <div class="skeleton-card"><div class="skeleton-img"></div><div class="p-4 space-y-3"><div class="skeleton-text w-1/3"></div><div class="skeleton-text w-full" style="height:1.25rem"></div><div class="skeleton-text w-2/3"></div></div></div>
      <div class="skeleton-card"><div class="skeleton-img"></div><div class="p-4 space-y-3"><div class="skeleton-text w-1/3"></div><div class="skeleton-text w-full" style="height:1.25rem"></div><div class="skeleton-text w-2/3"></div></div></div>
      <div class="skeleton-card hidden md:block"><div class="skeleton-img"></div><div class="p-4 space-y-3"><div class="skeleton-text w-1/3"></div><div class="skeleton-text w-full" style="height:1.25rem"></div><div class="skeleton-text w-2/3"></div></div></div>
      <div class="skeleton-card hidden xl:block"><div class="skeleton-img"></div><div class="p-4 space-y-3"><div class="skeleton-text w-1/3"></div><div class="skeleton-text w-full" style="height:1.25rem"></div><div class="skeleton-text w-2/3"></div></div></div>
      <div class="skeleton-card hidden md:block"><div class="skeleton-img"></div><div class="p-4 space-y-3"><div class="skeleton-text w-1/3"></div><div class="skeleton-text w-full" style="height:1.25rem"></div><div class="skeleton-text w-2/3"></div></div></div>
      <div class="skeleton-card hidden xl:block"><div class="skeleton-img"></div><div class="p-4 space-y-3"><div class="skeleton-text w-1/3"></div><div class="skeleton-text w-full" style="height:1.25rem"></div><div class="skeleton-text w-2/3"></div></div></div>
    </div>
  </main>

  <section class="max-w-6xl mx-auto px-6 md:px-12 pb-12 relative z-10">
    <div class="aeo-glass-card p-8 mt-8 max-w-5xl mx-auto relative overflow-hidden group">
      <div class="absolute top-0 left-0 w-full h-1 progress-pride-bg"></div>
      <div class="flex flex-col sm:flex-row items-start gap-8 relative z-10">
        <div class="hidden sm:flex text-[var(--color-toxic)] text-4xl mt-1 shadow-glow transition-transform group-hover:scale-110 duration-500">
          <i class="fas fa-search-location"></i>
        </div>
        <div>
          <h2 class="text-white text-2xl font-black mb-4 font-display uppercase tracking-widest leading-none shadow-glow">Birmingham has LGBTQ+ events most nights of the week, mostly in the Gay Village on Hurst Street.</h2>
          <p class="text-gray-200 text-lg leading-relaxed opacity-90 italic">Regular nights include drag shows at <a href="/venue/the-village-inn" class="text-[var(--color-pink)] font-bold hover:text-white transition-colors underline decoration-2 underline-offset-4">The Village Inn</a>, karaoke at <a href="/venue/the-fox" class="text-[var(--color-pink)] font-bold hover:text-white transition-colors underline decoration-2 underline-offset-4">The Fox</a>, and club nights at <a href="/venue/the-nightingale-club" class="text-[var(--color-pink)] font-bold hover:text-white transition-colors underline decoration-2 underline-offset-4">The Nightingale</a>.</p>
        </div>
      </div>
    </div>
  </section>

  <script is:inline>
    let allEvents = [];
    let activeFilter = 'all';
    let searchQuery = '';
    let currentOffset = 0;
    let hasMoreEvents = false;
    let isLoadingMore = false;
    let showNSFW = false;
    let totalUpcomingCount = 0;
    const PAGE_SIZE = 30;
    const grid = document.getElementById('event-grid');
    const countEl = document.getElementById('event-count');

    const searchInput = document.getElementById('event-search');
    if (searchInput) {
      searchInput.addEventListener('input', (e) => {
        searchQuery = e.target.value.toLowerCase();
        renderEvents();
      });
    }

    document.querySelectorAll('.date-filter').forEach(btn => {
      btn.addEventListener('click', () => {
        document.querySelectorAll('.date-filter').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        activeFilter = btn.dataset.filter;
        renderEvents();
      });
    });

    const urlParams = new URLSearchParams(window.location.search);
    const rangeParam = urlParams.get('range');
    if (rangeParam) {
      const btn = Array.from(document.querySelectorAll('.date-filter')).find(b => b.dataset.filter === rangeParam);
      if (btn) {
        document.querySelectorAll('.date-filter').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        activeFilter = rangeParam;
      }
    }

    const nsfwToggle = document.getElementById('nsfw-toggle');
    if (nsfwToggle) {
      nsfwToggle.addEventListener('click', () => {
        showNSFW = !showNSFW;
        nsfwToggle.setAttribute('aria-pressed', showNSFW);
        fetchEvents();
      });
    }

    async function fetchEvents(loadMore = false) {
      if (!loadMore) {
        currentOffset = 0;
        allEvents = [];
      }
      try {
        const res = await fetch(`/.netlify/functions/get-events?limit=${PAGE_SIZE}&offset=${currentOffset}&includeAdult=${showNSFW}`);
        if (!res.ok) throw new Error(res.status);
        const data = await res.json();
        if (data.success && data.events) {
          if (loadMore) allEvents = allEvents.concat(data.events);
          else allEvents = data.events;
          hasMoreEvents = data.hasMore || false;
          totalUpcomingCount = data.totalCount || allEvents.length;
          currentOffset += data.events.length;
        } else {
          throw new Error('No events in response');
        }
      } catch (err) {
        console.warn('Failed to fetch events:', err);
        if (!loadMore) allEvents = [];
      }
      renderEvents();
    }

    async function loadMoreEvents() {
      if (isLoadingMore || !hasMoreEvents) return;
      isLoadingMore = true;
      const btn = document.getElementById('load-more-btn');
      if (btn) { btn.textContent = 'LOADING...'; btn.disabled = true; }
      await fetchEvents(true);
      isLoadingMore = false;
    }
    window.loadMoreEvents = loadMoreEvents;

    function startOfDay(d) { const r = new Date(d); r.setUTCHours(0, 0, 0, 0); return r; }

    function getDateRange(filter) {
      const now = new Date();
      const today = startOfDay(now);
      if (filter === 'today') {
        const end = new Date(today); end.setUTCHours(23, 59, 59, 999);
        return { start: today, end };
      }
      if (filter === 'this-week') {
        const day = today.getUTCDay();
        const start = new Date(today); start.setUTCDate(start.getUTCDate() - day + 1);
        const end = new Date(start); end.setUTCDate(end.getUTCDate() + 6); end.setUTCHours(23, 59, 59, 999);
        return { start: today > start ? today : start, end };
      }
      if (filter === 'this-weekend') {
        const day = today.getUTCDay();
        const friday = new Date(today);
        friday.setUTCDate(friday.getUTCDate() + (5 - day + 7) % 7);
        if (day >= 5 || day === 0) friday.setTime(today.getTime());
        const sunday = new Date(friday);
        sunday.setUTCDate(friday.getUTCDate() + (day === 0 ? 0 : (7 - friday.getUTCDay())));
        sunday.setUTCHours(23, 59, 59, 999);
        return { start: today > friday ? today : friday, end: sunday };
      }
      if (filter === 'this-month') {
        const end = new Date(Date.UTC(today.getUTCFullYear(), today.getUTCMonth() + 1, 0, 23, 59, 59, 999));
        return { start: today, end };
      }
      return null;
    }

    function renderEvents() {
      const now = startOfDay(new Date());
      const range = getDateRange(activeFilter);

      let filtered = allEvents.filter(ev => {
        const d = new Date(ev.date);
        if (isNaN(d.getTime())) return false;
        if (d < now) return false;
        let cats = [];
        if (Array.isArray(ev.category)) cats = ev.category;
        else if (typeof ev.category === 'string') cats = ev.category.split(',').map(s => s.trim());
        const isNSFW = cats.includes('Adult') || cats.includes('Kink') || ev.ageRestriction === '18+';
        if (!showNSFW && isNSFW) return false;
        if (range) { if (d < range.start || d > range.end) return false; }
        if (searchQuery) {
          let vName = '';
          if (ev.venueName) vName = Array.isArray(ev.venueName) ? ev.venueName[0] : ev.venueName;
          else if (ev.venue && ev.venue.name) vName = Array.isArray(ev.venue.name) ? ev.venue.name[0] : ev.venue.name;
          const eventName = (ev.name || '').toLowerCase();
          const venueNameStr = vName.toLowerCase();
          if (!eventName.includes(searchQuery) && !venueNameStr.includes(searchQuery)) return false;
        }
        return true;
      });

      filtered.sort((a, b) => new Date(a.date) - new Date(b.date));

      if (searchQuery || activeFilter !== 'all') {
        countEl.textContent = filtered.length + ' of ' + totalUpcomingCount + ' events';
      } else if (hasMoreEvents) {
        countEl.textContent = 'Showing ' + filtered.length + ' of ' + totalUpcomingCount + ' upcoming events';
      } else {
        countEl.textContent = filtered.length === 1 ? '1 upcoming event' : filtered.length + ' upcoming events';
      }

      const prideBanner = document.getElementById('pride-banner');

      if (filtered.length === 0) {
        prideBanner.classList.add('hidden');
        let emptyMsg = '';
        if (searchQuery) emptyMsg = 'We couldn\'t find any events matching "<span class="text-white font-bold">' + escapeHtml(searchQuery) + '</span>".';
        else if (activeFilter === 'all') emptyMsg = 'Check back soon — new events are added regularly.';
        else emptyMsg = 'There are no events falling in this specific timeframe.';

        let resetBtn = '';
        if (activeFilter !== 'all' || searchQuery) {
          resetBtn = '<button class="filter-pill active mx-auto" onclick="resetSearchAndFilter()" style="display:inline-flex;">View All Events</button>';
        }
        grid.innerHTML = '<div class="col-span-full"><div class="bg-[#111] border border-white/10 rounded-2xl p-12 text-center max-w-2xl mx-auto shadow-2xl"><div class="w-20 h-20 bg-black/50 rounded-full flex items-center justify-center mx-auto mb-6 border border-white/5"><i class="fas fa-search text-3xl text-gray-500"></i></div><h2 class="text-2xl font-bold text-white font-display uppercase mb-3 tracking-wide">No Events Found</h2><p class="text-gray-400 text-lg mb-8 max-w-md mx-auto leading-relaxed">' + emptyMsg + '</p>' + resetBtn + '</div></div>';
        return;
      }

      const hasPride = filtered.some(ev => (Array.isArray(ev.category) ? ev.category : []).includes('Pride'));
      prideBanner.classList.toggle('hidden', !hasPride);

      let html = '';
      let currentGroup = '';
      filtered.forEach((ev, index) => {
        const dateObj = new Date(ev.date);
        let dateStr = 'Date TBC';
        if (!isNaN(dateObj.getTime())) {
          dateStr = dateObj.toLocaleDateString('en-GB', { weekday: 'long', day: 'numeric', month: 'long', timeZone: 'UTC' }).toUpperCase();
        }
        if (dateStr !== currentGroup) {
          html += '<div class="col-span-full mt-8 mb-2 border-b border-white/10 pb-3 flex items-center gap-4"><h2 class="text-white font-bold text-lg md:text-xl tracking-widest uppercase m-0 leading-none">' + dateStr + '</h2></div>';
          currentGroup = dateStr;
        }
        html += createCard(ev, index === 0);
      });

      if (hasMoreEvents && activeFilter === 'all' && !searchQuery) {
        html += '<div class="col-span-full flex justify-center mt-8"><button id="load-more-btn" onclick="loadMoreEvents()" class="filter-pill" style="font-size:1rem; padding:0.75rem 2.5rem; background:#111; border:1px solid rgba(255,255,255,0.1);">LOAD MORE EVENTS</button></div>';
      }
      grid.innerHTML = html;
    }

    function resetSearchAndFilter() {
      if (searchInput) searchInput.value = '';
      searchQuery = '';
      resetFilter();
    }
    window.resetSearchAndFilter = resetSearchAndFilter;

    function resetFilter() {
      document.querySelectorAll('.date-filter').forEach(b => b.classList.remove('active'));
      document.querySelector('.date-filter[data-filter="all"]').classList.add('active');
      activeFilter = 'all';
      renderEvents();
    }

    function escapeHtml(unsafe) {
      if (!unsafe) return '';
      return unsafe.toString().replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;').replace(/'/g, '&#039;');
    }

    function formatDate(dateStr) {
      const d = new Date(dateStr);
      if (isNaN(d.getTime())) return 'Date TBC';
      return d.toLocaleDateString('en-GB', { weekday: 'short', day: 'numeric', month: 'short', timeZone: 'UTC' });
    }

    function formatTime(dateStr) {
      const d = new Date(dateStr);
      if (isNaN(d.getTime())) return '';
      const s = typeof dateStr === 'string' ? dateStr : '';
      if (!s.includes('T') || s.includes('T00:00')) return '';
      const t = d.toLocaleTimeString('en-GB', { hour: 'numeric', minute: '2-digit', timeZone: 'UTC' });
      return (t === '0:00' || t === '00:00') ? '' : t;
    }

    function createCard(ev, isFirst) {
      const date = formatDate(ev.date);
      const time = formatTime(ev.date);
      const rawUrl = ev.image ? (typeof ev.image === 'string' ? ev.image : ev.image.url) : null;
      const isPlaceholder = !rawUrl || rawUrl.includes('placehold');
      let imgHtml = '';
      if (isPlaceholder) {
        imgHtml = '<div class="w-full aspect-[4/3] bg-gradient-to-br from-[#1a0a2e] to-[#0D0115] flex items-center justify-center"><i class="fas fa-image text-4xl text-gray-800"></i></div>';
      } else {
        if (isFirst) {
          imgHtml = '<img src="' + escapeHtml(rawUrl) + '" alt="' + escapeHtml(ev.name || '') + '" fetchpriority="high" class="w-full aspect-[4/3] object-cover bg-[#111] transition-transform duration-500 group-hover:scale-[1.03]">';
          if (!document.querySelector('link[rel="preload"][href="' + escapeHtml(rawUrl) + '"]')) {
            document.head.insertAdjacentHTML('beforeend', '<link rel="preload" as="image" href="' + escapeHtml(rawUrl) + '" fetchpriority="high">');
          }
        } else {
          imgHtml = '<img src="' + escapeHtml(rawUrl) + '" alt="' + escapeHtml(ev.name || '') + '" loading="lazy" class="w-full aspect-[4/3] object-cover bg-[#111] transition-transform duration-500 group-hover:scale-[1.03]">';
        }
      }
      let venue = '';
      if (ev.venueName) venue = Array.isArray(ev.venueName) ? ev.venueName[0] : ev.venueName;
      else if (ev.venue && ev.venue.name) venue = Array.isArray(ev.venue.name) ? ev.venue.name[0] : ev.venue.name;
      let cats = [];
      if (Array.isArray(ev.category)) cats = ev.category;
      else if (typeof ev.category === 'string') cats = ev.category.split(',').map(s => s.trim());
      const isNSFW = cats.includes('Adult') || cats.includes('Kink') || ev.ageRestriction === '18+';
      const slug = ev.slug || '';
      return '<a href="/event/' + slug + '" class="group flex flex-col bg-[#0A0A0A] border-2 border-[#1E1E1E] hover:border-[var(--color-purple)] rounded-lg overflow-hidden transition-all duration-300 hover:-translate-y-1 hover:shadow-[0_8px_30px_rgba(155,93,229,0.3)] focus-visible:outline-none focus-visible:ring-4 focus-visible:ring-[var(--color-toxic)]">' + imgHtml + '<div class="p-4 md:p-5 flex flex-col flex-grow justify-between"><div><p class="text-[var(--color-toxic)] font-bold text-xs uppercase tracking-widest mb-2 flex items-center"><i class="fas fa-calendar-day mr-1.5 opacity-80"></i>' + date + (time ? ' <span class="text-white ml-2 flex items-center"><i class="fas fa-clock mr-1.5 text-[var(--color-toxic)] opacity-80"></i>' + time + '</span>' : '') + '</p><h3 class="text-xl font-bold text-white font-display leading-tight mb-2 group-hover:text-[var(--color-toxic)] transition-colors">' + escapeHtml(ev.name || 'Untitled Event') + '</h3>' + (venue ? '<p class="text-gray-300 font-medium text-sm mb-4"><i class="fas fa-map-marker-alt mr-1.5 text-[var(--color-pink)]"></i>' + escapeHtml(venue) + '</p>' : '') + '</div><div class="flex flex-wrap gap-2 mt-auto">' + (cats.includes('Pride') ? '<span class="bg-[var(--color-toxic)] text-black text-[10px] uppercase font-bold px-2 py-0.5 rounded-sm">PRIDE</span>' : '') + (isNSFW ? '<span class="bg-[var(--color-pink)] text-white text-[10px] uppercase font-bold px-2 py-0.5 rounded-sm">18+</span>' : '') + '</div></div></a>';
    }

    fetchEvents();
  </script>
</PublicLayout>
