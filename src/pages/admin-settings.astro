---
import AdminLayout from '../components/AdminLayout.astro';
---
<AdminLayout title="Admin Dashboard" activeNav="admin-settings.html" breadcrumbSection="System" breadcrumbPage="Settings Dashboard">
  <Fragment slot="head">
    <script is:inline src="/js/admin-dashboard.js"></script>
    <script is:inline src="/js/push-notifications.js"></script>
    <script is:inline src="/js/admin-notification-poller.js"></script>
    <script is:inline src="/js/main.js"></script>
  </Fragment>

<div class="max-w-7xl mx-auto px-4 sm:px-8 py-8 md:py-12">

        <section class="text-center mb-8">
            <div class="text-center mb-16">
                <h1 class="text-2xl font-bold uppercase tracking-widest text-white mb-2">Admin Dashboard</h1>
                <p class="text-sm text-gray-500 font-medium tracking-wide uppercase">Manage your LGBTQ+ events platform</p>
            </div>

            <!-- Dashboard Stats -->
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-12">
                <a href="/admin-approvals.html"
                    class="bg-[#111] border border-white/5 rounded-xl hover:bg-[#1A1A1A] rounded-xl p-6 relative group hover:scale-105 transition-transform cursor-pointer">
                    <div class="flex items-center justify-between">
                        <div>
                            <p class="text-gray-400 text-sm">Pending Events</p>
                            <p class="text-3xl font-bold text-white" id="pending-events-count">-</p>
                        </div>
                        <div class="text-4xl text-accent-color group-hover:scale-110 transition-transform">
                            <i class="fas fa-calendar-clock"></i>
                        </div>
                    </div>
                    <div id="pending-events-badge" class="notification-badge hidden">0</div>
                    <div
                        class="absolute inset-0 rounded-xl border-2 border-transparent group-hover:border-accent-color/30 transition-colors">
                    </div>
                </a>

                <a href="/admin-approvals.html"
                    class="bg-[#111] border border-white/5 rounded-xl hover:bg-[#1A1A1A] rounded-xl p-6 relative group hover:scale-105 transition-transform cursor-pointer">
                    <div class="flex items-center justify-between">
                        <div>
                            <p class="text-gray-400 text-sm">Pending Venues</p>
                            <p class="text-3xl font-bold text-white" id="pending-venues-count">-</p>
                        </div>
                        <div class="text-4xl text-accent-color group-hover:scale-110 transition-transform">
                            <i class="fas fa-map-marker-alt"></i>
                        </div>
                    </div>
                    <div id="pending-venues-badge" class="notification-badge hidden">0</div>
                    <div
                        class="absolute inset-0 rounded-xl border-2 border-transparent group-hover:border-accent-color/30 transition-colors">
                    </div>
                </a>

                <div class="bg-[#111] border border-white/5 rounded-xl hover:bg-[#1A1A1A] rounded-xl p-6 relative">
                    <div class="flex items-center justify-between">
                        <div>
                            <p class="text-gray-400 text-sm">Total Events</p>
                            <p class="text-3xl font-bold text-white" id="total-events-count">-</p>
                        </div>
                        <div class="text-4xl text-accent-color">
                            <i class="fas fa-calendar-check"></i>
                        </div>
                    </div>
                </div>

                <div class="bg-[#111] border border-white/5 rounded-xl hover:bg-[#1A1A1A] rounded-xl p-6 relative">
                    <div class="flex items-center justify-between">
                        <div>
                            <p class="text-gray-400 text-sm">Total Venues</p>
                            <p class="text-3xl font-bold text-white" id="total-venues-count">-</p>
                        </div>
                        <div class="text-4xl text-accent-color">
                            <i class="fas fa-building"></i>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Quick Actions -->
            <div class="bg-[#0A0A0A] border border-white/5 shadow-2xl p-8 md:p-12 mb-8 rounded-2xl">
                <h2 class="font-anton text-3xl text-white mb-6 border-b border-gray-700 pb-2">
                    <i class="fas fa-bolt mr-3 text-[var(--color-toxic)]"></i>Quick Actions
                </h2>
                <p class="text-gray-400 mb-8">Essential tools for managing submissions and content.</p>

                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                    <a href="/admin-approvals.html" class="bg-[#111] border border-white/5 rounded-xl block hover:border-[var(--color-toxic)] hover:bg-[#1A1A1A] rounded-xl p-6 relative group">
                        <div class="flex items-center justify-between mb-4">
                            <div class="text-2xl text-accent-color">
                                <i class="fas fa-tasks"></i>
                            </div>
                            <div id="approval-badge" class="notification-badge hidden">0</div>
                        </div>
                        <h3 class="text-xl font-bold text-white mb-2">Review Submissions</h3>
                        <p class="text-gray-400 text-sm">Approve or reject pending events and venues</p>
                        <div class="mt-4 text-accent-color group-hover:translate-x-2 transition-transform">
                            <i class="fas fa-arrow-right"></i>
                        </div>
                    </a>

                    <a href="/admin-edit-events.html" class="bg-[#111] border border-white/5 rounded-xl block hover:border-[var(--color-toxic)] hover:bg-[#1A1A1A] rounded-xl p-6 relative group">
                        <div class="flex items-center justify-between mb-4">
                            <div class="text-2xl text-accent-color">
                                <i class="fas fa-edit"></i>
                            </div>
                        </div>
                        <h3 class="text-xl font-bold text-white mb-2">Manage Events</h3>
                        <p class="text-gray-400 text-sm">Edit, delete, and manage all events</p>
                        <div class="mt-4 text-accent-color group-hover:translate-x-2 transition-transform">
                            <i class="fas fa-arrow-right"></i>
                        </div>
                    </a>

                    <a href="/admin-manage-venues.html" class="bg-[#111] border border-white/5 rounded-xl block hover:border-[var(--color-toxic)] hover:bg-[#1A1A1A] rounded-xl p-6 relative group">
                        <div class="flex items-center justify-between mb-4">
                            <div class="text-2xl text-accent-color">
                                <i class="fas fa-building"></i>
                            </div>
                        </div>
                        <h3 class="text-xl font-bold text-white mb-2">Manage Venues</h3>
                        <p class="text-gray-400 text-sm">Add, edit, and manage venue information</p>
                        <div class="mt-4 text-accent-color group-hover:translate-x-2 transition-transform">
                            <i class="fas fa-arrow-right"></i>
                        </div>
                    </a>

                    <a href="/admin-poster-tool.html" class="bg-[#111] border border-white/5 rounded-xl block hover:border-[var(--color-toxic)] hover:bg-[#1A1A1A] rounded-xl p-6 relative group">
                        <div class="flex items-center justify-between mb-4">
                            <div class="text-2xl text-accent-color">
                                <i class="fas fa-image"></i>
                            </div>
                        </div>
                        <h3 class="text-xl font-bold text-white mb-2">Poster Parser</h3>
                        <p class="text-gray-400 text-sm">Extract event details from uploaded posters</p>
                        <div class="mt-4 text-accent-color group-hover:translate-x-2 transition-transform">
                            <i class="fas fa-arrow-right"></i>
                        </div>
                    </a>

                    <a href="/admin-email-management.html" class="bg-[#111] border border-white/5 rounded-xl block hover:border-[var(--color-toxic)] hover:bg-[#1A1A1A] rounded-xl p-6 relative group">
                        <div class="flex items-center justify-between mb-4">
                            <div class="text-2xl text-accent-color">
                                <i class="fas fa-envelope"></i>
                            </div>
                            <span
                                class="bg-green-600 text-white px-2 py-1 rounded-full text-xs font-semibold">NEW</span>
                        </div>
                        <h3 class="text-xl font-bold text-white mb-2">Email Management</h3>
                        <p class="text-gray-400 text-sm">Manage email notifications and templates</p>
                        <div class="mt-4 text-accent-color group-hover:translate-x-2 transition-transform">
                            <i class="fas fa-arrow-right"></i>
                        </div>
                    </a>

                    <a href="/admin-social-assets.html" class="bg-[#111] border border-white/5 rounded-xl block hover:border-[var(--color-toxic)] hover:bg-[#1A1A1A] rounded-xl p-6 relative group">
                        <div class="flex items-center justify-between mb-4">
                            <div class="text-2xl text-accent-color">
                                <i class="fas fa-images"></i>
                            </div>
                            <span
                                class="bg-purple-600 text-white px-2 py-1 rounded-full text-xs font-semibold">NEW</span>
                        </div>
                        <h3 class="text-xl font-bold text-white mb-2">Social Assets</h3>
                        <p class="text-gray-400 text-sm">On-brand Instagram posts &amp; stories for upcoming events</p>
                        <div class="mt-4 text-accent-color group-hover:translate-x-2 transition-transform">
                            <i class="fas fa-arrow-right"></i>
                        </div>
                    </a>

                    <a href="/admin-add-venue.html" class="bg-[#111] border border-white/5 rounded-xl block hover:border-[var(--color-toxic)] hover:bg-[#1A1A1A] rounded-xl p-6 relative group">
                        <div class="flex items-center justify-between mb-4">
                            <div class="text-2xl text-accent-color">
                                <i class="fas fa-plus-circle"></i>
                            </div>
                        </div>
                        <h3 class="text-xl font-bold text-white mb-2">Add Venue</h3>
                        <p class="text-gray-400 text-sm">Quickly add a new venue to the database</p>
                        <div class="mt-4 text-accent-color group-hover:translate-x-2 transition-transform">
                            <i class="fas fa-arrow-right"></i>
                        </div>
                    </a>

                    <a href="/admin-migrate.html" class="bg-[#111] border border-white/5 rounded-xl block hover:border-[var(--color-toxic)] hover:bg-[#1A1A1A] rounded-xl p-6 relative group">
                        <div class="flex items-center justify-between mb-4">
                            <div class="text-2xl text-accent-color">
                                <i class="fas fa-database"></i>
                            </div>
                        </div>
                        <h3 class="text-xl font-bold text-white mb-2">Data Migration</h3>
                        <p class="text-gray-400 text-sm">Tools for data cleanup and migration</p>
                        <div class="mt-4 text-accent-color group-hover:translate-x-2 transition-transform">
                            <i class="fas fa-arrow-right"></i>
                        </div>
                    </a>

                    <a href="/admin/import-events" class="bg-[#111] border border-white/5 rounded-xl block hover:border-[var(--color-toxic)] hover:bg-[#1A1A1A] rounded-xl p-6 relative group">
                        <div class="flex items-center justify-between mb-4">
                            <div class="text-2xl text-accent-color">
                                <i class="fas fa-file-import"></i>
                            </div>
                            <span class="bg-blue-600 text-white px-2 py-1 rounded-full text-xs font-semibold">NEW</span>
                        </div>
                        <h3 class="text-xl font-bold text-white mb-2">Bulk Import Events</h3>
                        <p class="text-gray-400 text-sm">Import events instantly using JSON payloads</p>
                        <div class="mt-4 text-accent-color group-hover:translate-x-2 transition-transform">
                            <i class="fas fa-arrow-right"></i>
                        </div>
                    </a>

                    <button id="rebuild-venues-btn" class="bg-[#111] border border-white/5 rounded-xl block hover:border-[var(--color-toxic)] hover:bg-[#1A1A1A] rounded-xl p-6 relative group text-left w-full">
                        <div class="flex items-center justify-between mb-4">
                            <div class="text-2xl text-accent-color">
                                <i class="fas fa-sync-alt"></i>
                            </div>
                            <div id="rebuild-status" class="hidden">
                                <div class="animate-spin rounded-full h-6 w-6 border-b-2 border-accent-color"></div>
                            </div>
                        </div>
                        <h3 class="text-xl font-bold text-white mb-2">Rebuild Venue Pages</h3>
                        <p class="text-gray-400 text-sm">Regenerate all static venue pages with latest data</p>
                        <div class="flex items-center justify-between mt-4">
                            <div class="text-accent-color group-hover:translate-x-2 transition-transform">
                                <i class="fas fa-arrow-right"></i>
                            </div>
                            <div id="last-rebuild-info" class="text-xs text-gray-500 hidden">
                                <span id="last-rebuild-time">-</span>
                            </div>
                        </div>
                    </button>

                    <button id="rebuild-events-btn" class="bg-[#111] border border-white/5 rounded-xl block hover:border-[var(--color-toxic)] hover:bg-[#1A1A1A] rounded-xl p-6 relative group text-left w-full">
                        <div class="flex items-center justify-between mb-4">
                            <div class="text-2xl text-accent-color">
                                <i class="fas fa-calendar-alt"></i>
                            </div>
                            <div id="rebuild-events-status" class="hidden">
                                <div class="animate-spin rounded-full h-6 w-6 border-b-2 border-accent-color"></div>
                            </div>
                        </div>
                        <h3 class="text-xl font-bold text-white mb-2">Rebuild Event Pages</h3>
                        <p class="text-gray-400 text-sm">Regenerate all static event pages with latest data</p>
                        <div class="flex items-center justify-between mt-4">
                            <div class="text-accent-color group-hover:translate-x-2 transition-transform">
                                <i class="fas fa-arrow-right"></i>
                            </div>
                            <div id="last-rebuild-events-info" class="text-xs text-gray-500 hidden">
                                <span id="last-rebuild-events-time">-</span>
                            </div>
                        </div>
                    </button>
                </div>
            </div>

            <!-- System Status -->
            <div id="system-status" class="bg-[#0A0A0A] border border-white/5 shadow-2xl p-8 md:p-12 rounded-2xl">
                <div class="flex items-center justify-between mb-6 border-b border-gray-700 pb-2">
                    <h2 class="font-anton text-3xl text-white">
                        <i class="fas fa-server mr-3 text-[var(--color-toxic)]"></i>System Status
                    </h2>
                    <div class="flex items-center gap-3">
                        <div class="flex items-center space-x-2">
                            <div id="system-status-indicator" class="w-3 h-3 bg-gray-500 rounded-full"></div>
                            <span id="system-status-text" class="text-gray-400 text-sm">Checking...</span>
                        </div>
                        <a href="/admin-system-status.html"
                            class="bg-[var(--color-toxic)] text-black font-bold uppercase tracking-widest hover:bg-white transition-colors px-4 py-2 rounded-lg text-sm font-semibold flex items-center gap-2">
                            <i class="fas fa-chart-line"></i>
                            Detailed View
                        </a>
                    </div>
                </div>
                <p class="text-gray-400 mb-8">Real-time system health monitoring and performance metrics.</p>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
                    <div class="bg-[#111] border border-white/5 rounded-xl block hover:border-[var(--color-toxic)] hover:bg-[#1A1A1A] rounded-xl p-6">
                        <div class="flex items-center justify-between mb-4">
                            <h3 class="text-xl font-bold text-white">API Status</h3>
                            <div class="flex items-center space-x-2">
                                <div id="api-status-indicator" class="w-3 h-3 bg-gray-500 rounded-full"></div>
                                <span id="api-status-text" class="text-gray-400 text-sm">Checking...</span>
                            </div>
                        </div>
                        <p class="text-gray-400 text-sm">All backend services are running normally</p>
                    </div>

                    <div class="bg-[#111] border border-white/5 rounded-xl block hover:border-[var(--color-toxic)] hover:bg-[#1A1A1A] rounded-xl p-6">
                        <div class="flex items-center justify-between mb-4">
                            <h3 class="text-xl font-bold text-white">Database</h3>
                            <div class="flex items-center space-x-2">
                                <div id="db-status-indicator" class="w-3 h-3 bg-gray-500 rounded-full"></div>
                                <span id="db-status-text" class="text-gray-400 text-sm">Checking...</span>
                            </div>
                        </div>
                        <p class="text-gray-400 text-sm">Firestore database is connected and active</p>
                    </div>
                </div>

                <!-- Quick Status Overview -->
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4 mb-6">
                    <div class="bg-[#111] border border-white/5 rounded-xl hover:bg-[#1A1A1A] rounded-lg p-4 text-center">
                        <div id="overall-status" class="text-2xl font-bold text-gray-400 mb-1">--</div>
                        <div class="text-xs text-gray-500">Overall Status</div>
                    </div>
                    <div class="bg-[#111] border border-white/5 rounded-xl hover:bg-[#1A1A1A] rounded-lg p-4 text-center">
                        <div id="last-check" class="text-2xl font-bold text-gray-400 mb-1">--</div>
                        <div class="text-xs text-gray-500">Last Check</div>
                    </div>
                    <div class="bg-[#111] border border-white/5 rounded-xl hover:bg-[#1A1A1A] rounded-lg p-4 text-center">
                        <div id="tests-passed" class="text-2xl font-bold text-gray-400 mb-1">--</div>
                        <div class="text-xs text-gray-500">Tests Passed</div>
                    </div>
                    <div class="bg-[#111] border border-white/5 rounded-xl hover:bg-[#1A1A1A] rounded-lg p-4 text-center">
                        <div id="notifications" class="text-2xl font-bold text-gray-400 mb-1">--</div>
                        <div class="text-xs text-gray-500">Notifications</div>
                    </div>
                </div>

                <!-- System Metrics -->
                <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-6">
                    <div class="bg-[#111] border border-white/5 rounded-xl hover:bg-[#1A1A1A] rounded-lg p-4">
                        <div class="flex items-center justify-between">
                            <div>
                                <div class="text-sm text-gray-400">Uptime</div>
                                <div id="uptime-display" class="text-xl font-bold">--</div>
                            </div>
                            <div class="text-2xl text-accent-color">
                                <i class="fas fa-clock"></i>
                            </div>
                        </div>
                    </div>
                    <div class="bg-[#111] border border-white/5 rounded-xl hover:bg-[#1A1A1A] rounded-lg p-4">
                        <div class="flex items-center justify-between">
                            <div>
                                <div class="text-sm text-gray-400">Response Time</div>
                                <div id="response-time" class="text-xl font-bold">--</div>
                            </div>
                            <div class="text-2xl text-accent-color">
                                <i class="fas fa-tachometer-alt"></i>
                            </div>
                        </div>
                    </div>
                    <div class="bg-[#111] border border-white/5 rounded-xl hover:bg-[#1A1A1A] rounded-lg p-4">
                        <div class="flex items-center justify-between">
                            <div>
                                <div class="text-sm text-gray-400">Cache Status</div>
                                <div id="cache-status" class="text-xl font-bold">--</div>
                            </div>
                            <div class="text-2xl text-accent-color">
                                <i class="fas fa-database"></i>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Quick Actions -->
                <div class="flex flex-wrap gap-3 mt-6">
                    <button id="quick-health-check"
                        class="bg-[#111] border border-white/10 text-white font-bold uppercase tracking-widest hover:bg-[#1A1A1A] transition-colors px-4 py-2 rounded-lg text-sm font-semibold flex items-center gap-2">
                        <i class="fas fa-heartbeat"></i>
                        Quick Health Check
                    </button>
                    <button id="refresh-status"
                        class="bg-[#111] border border-white/10 text-white font-bold uppercase tracking-widest hover:bg-[#1A1A1A] transition-colors px-4 py-2 rounded-lg text-sm font-semibold flex items-center gap-2">
                        <i class="fas fa-sync-alt"></i>
                        Refresh Status
                    </button>
                    <button id="test-notification"
                        class="bg-[#111] border border-white/10 text-white font-bold uppercase tracking-widest hover:bg-[#1A1A1A] transition-colors px-4 py-2 rounded-lg text-sm font-semibold flex items-center gap-2">
                        <i class="fas fa-bell"></i>
                        Test Notification
                    </button>
                    <button id="test-notification-system"
                        class="bg-[#111] border border-white/10 text-white font-bold uppercase tracking-widest hover:bg-[#1A1A1A] transition-colors px-4 py-2 rounded-lg text-sm font-semibold flex items-center gap-2">
                        <i class="fas fa-cog"></i>
                        Test System
                    </button>
                </div>
            </div>
            </div>

<!-- Hidden elements for admin dashboard compatibility -->
    <div id="recent-activity" class="hidden"></div>
    <form id="settings-form" class="hidden"></form>


<script is:inline>
        // System Status Dashboard
        async function loadSystemStatus() {
            console.log('Loading system status...');

            // Show loading state
            const refreshBtn = document.getElementById('refresh-status');
            const originalText = refreshBtn.innerHTML;
            refreshBtn.disabled = true;
            refreshBtn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Loading...';

            try {
                const response = await fetch('/.netlify/functions/get-system-status');
                console.log('System status response:', response.status);

                if (!response.ok) {
                    const errorText = await response.text();
                    console.error('System status response error:', errorText);
                    throw new Error(`HTTP ${response.status}: ${errorText}`);
                }

                const data = await response.json();
                console.log('System status data:', data);

                if (data.success && data.data) {
                    updateSystemStatus(data.data);
                } else {
                    console.error('System status data invalid:', data);
                    showError('Failed to load system status: Invalid data');
                }
            } catch (error) {
                console.error('Error loading system status:', error);
                showError('Failed to load system status: ' + error.message);

                // Set unknown status
                const overallStatus = document.getElementById('overall-status');
                overallStatus.textContent = '❓';
                overallStatus.className = 'text-2xl font-bold text-gray-400 mb-1';

                const lastCheck = document.getElementById('last-check');
                lastCheck.textContent = 'Error';

                const testsPassed = document.getElementById('tests-passed');
                testsPassed.textContent = '--';
            } finally {
                // Restore button state
                refreshBtn.disabled = false;
                refreshBtn.innerHTML = originalText;
            }
        }

        function updateSystemStatus(status) {
            console.log('Updating system status with:', status);

            // Update system status indicator
            const systemIndicator = document.getElementById('system-status-indicator');
            const systemText = document.getElementById('system-status-text');

            // Update overall status
            const overallStatus = document.getElementById('overall-status');
            if (status.overallStatus === 'healthy') {
                overallStatus.textContent = '✅';
                overallStatus.className = 'text-2xl font-bold text-green-400 mb-1';
                systemIndicator.className = 'w-3 h-3 bg-green-500 rounded-full animate-pulse';
                systemText.textContent = 'Healthy';
                systemText.className = 'text-green-400 text-sm';
            } else if (status.overallStatus === 'degraded') {
                overallStatus.textContent = '⚠️';
                overallStatus.className = 'text-2xl font-bold text-yellow-400 mb-1';
                systemIndicator.className = 'w-3 h-3 bg-yellow-500 rounded-full animate-pulse';
                systemText.textContent = 'Degraded';
                systemText.className = 'text-yellow-400 text-sm';
            } else if (status.overallStatus === 'critical') {
                overallStatus.textContent = '❌';
                overallStatus.className = 'text-2xl font-bold text-red-400 mb-1';
                systemIndicator.className = 'w-3 h-3 bg-red-500 rounded-full';
                systemText.textContent = 'Critical';
                systemText.className = 'text-red-400 text-sm';
            } else {
                overallStatus.textContent = '❓';
                overallStatus.className = 'text-2xl font-bold text-gray-400 mb-1';
                systemIndicator.className = 'w-3 h-3 bg-gray-500 rounded-full';
                systemText.textContent = 'Unknown';
                systemText.className = 'text-gray-400 text-sm';
            }

            // Update last check
            const lastCheck = document.getElementById('last-check');
            if (status.lastRun) {
                const timeAgo = getTimeAgo(new Date(status.lastRun));
                lastCheck.textContent = timeAgo;
            } else {
                lastCheck.textContent = 'Never';
            }

            // Update tests passed
            const testsPassed = document.getElementById('tests-passed');
            if (status.hasRunTests && status.totalTests > 0) {
                testsPassed.textContent = `${status.passedTests}/${status.totalTests}`;
            } else {
                testsPassed.textContent = '--';
            }

            // Update uptime
            const uptimeDisplay = document.getElementById('uptime-display');
            if (status.uptime && status.uptime.uptime) {
                uptimeDisplay.textContent = status.uptime.uptime;
            } else {
                uptimeDisplay.textContent = '--';
            }

            // Update API and DB status
            updateServiceStatus();
        }

        async function updateServiceStatus() {
            try {
                // Test API status with timing (using Firestore endpoint)
                const apiStart = Date.now();
                const apiResponse = await fetch('/.netlify/functions/get-events-simple');
                const apiDuration = Date.now() - apiStart;

                const apiIndicator = document.getElementById('api-status-indicator');
                const apiText = document.getElementById('api-status-text');
                const responseTimeElement = document.getElementById('response-time');

                if (apiResponse.ok) {
                    apiIndicator.className = 'w-3 h-3 bg-green-500 rounded-full animate-pulse';
                    apiText.textContent = 'Online';
                    apiText.className = 'text-green-400 text-sm';
                    responseTimeElement.textContent = `${apiDuration}ms`;
                } else {
                    apiIndicator.className = 'w-3 h-3 bg-red-500 rounded-full';
                    apiText.textContent = 'Error';
                    apiText.className = 'text-red-400 text-sm';
                    responseTimeElement.textContent = 'Error';
                }

                // Test Firestore status (using Firestore endpoint)
                const dbStart = Date.now();
                const dbResponse = await fetch('/.netlify/functions/get-pending-items');
                const dbDuration = Date.now() - dbStart;

                const dbIndicator = document.getElementById('db-status-indicator');
                const dbText = document.getElementById('db-status-text');
                const cacheStatusElement = document.getElementById('cache-status');

                if (dbResponse.ok) {
                    dbIndicator.className = 'w-3 h-3 bg-green-500 rounded-full animate-pulse';
                    dbText.textContent = 'Firestore Connected';
                    dbText.className = 'text-green-400 text-sm';
                    cacheStatusElement.textContent = 'Active';
                } else {
                    dbIndicator.className = 'w-3 h-3 bg-red-500 rounded-full';
                    dbText.textContent = 'Firestore Error';
                    dbText.className = 'text-red-400 text-sm';
                    cacheStatusElement.textContent = 'Error';
                }

                // Update notifications count
                try {
                    const notificationsResponse = await fetch('/.netlify/functions/get-notifications');
                    const notificationsElement = document.getElementById('notifications');

                    if (notificationsResponse.ok) {
                        const data = await notificationsResponse.json();
                        if (data.success && data.data) {
                            const recentNotifications = data.data.filter(n => {
                                const notificationTime = new Date(n.timestamp);
                                const oneHourAgo = new Date(Date.now() - 60 * 60 * 1000);
                                return notificationTime > oneHourAgo;
                            });
                            notificationsElement.textContent = recentNotifications.length;
                        } else {
                            notificationsElement.textContent = '0';
                        }
                    } else {
                        notificationsElement.textContent = '--';
                    }
                } catch (error) {
                    console.error('Error fetching notifications:', error);
                    document.getElementById('notifications').textContent = '--';
                }

            } catch (error) {
                console.error('Error updating service status:', error);

                // Set error state
                document.getElementById('api-status-indicator').className = 'w-3 h-3 bg-red-500 rounded-full';
                document.getElementById('api-status-text').textContent = 'Error';
                document.getElementById('api-status-text').className = 'text-red-400 text-sm';

                document.getElementById('db-status-indicator').className = 'w-3 h-3 bg-red-500 rounded-full';
                document.getElementById('db-status-text').textContent = 'Firestore Error';
                document.getElementById('db-status-text').className = 'text-red-400 text-sm';
            }
        }

        async function runQuickHealthCheck() {
            const btn = document.getElementById('quick-health-check');
            const originalText = btn.innerHTML;

            btn.disabled = true;
            btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Checking...';

            try {
                const response = await fetch('/.netlify/functions/run-system-tests', {
                    method: 'POST'
                });

                const data = await response.json();

                if (data.success) {
                    showSuccess(`Health check completed: ${data.data.passed}/${data.data.totalTests} tests passed`);
                    loadSystemStatus(); // Refresh the status
                } else {
                    showError('Health check failed');
                }
            } catch (error) {
                console.error('Error running health check:', error);
                showError('Health check failed');
            } finally {
                btn.disabled = false;
                btn.innerHTML = originalText;
            }
        }

        async function testNotification() {
            try {
                // Initialize push notification service if not already done
                if (!window.pushNotificationService) {
                    window.pushNotificationService = new PushNotificationService();
                    await window.pushNotificationService.initialize();
                }

                if (window.pushNotificationService.isEnabled()) {
                    const success = await window.pushNotificationService.sendTestNotification();
                    if (success) {
                        showSuccess('Test notification sent! Check your browser notifications.');
                    } else {
                        showError('Failed to send test notification. Check browser permissions.');
                    }
                } else {
                    // Try to enable notifications
                    const enabled = await window.pushNotificationService.requestPermission();
                    if (enabled) {
                        const success = await window.pushNotificationService.sendTestNotification();
                        if (success) {
                            showSuccess('Notifications enabled and test sent!');
                        } else {
                            showError('Failed to send test notification after enabling.');
                        }
                    } else {
                        showError('Push notifications not enabled. Please allow notifications in your browser settings.');
                    }
                }
            } catch (error) {
                console.error('Error in test notification:', error);
                showError('Error sending test notification: ' + error.message);
            }
        }

        async function testNotificationSystem() {
            const btn = document.getElementById('test-notification-system');
            const originalText = btn.innerHTML;

            btn.disabled = true;
            btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Testing...';

            try {
                const response = await fetch('/.netlify/functions/test-notification-system');
                const data = await response.json();

                if (data.success) {
                    showSuccess('Notification system test completed: ' + data.message);
                    console.log('Test result:', data);
                } else {
                    showError('Notification system test failed: ' + data.error);
                }
            } catch (error) {
                console.error('Error testing notification system:', error);
                showError('Error testing notification system: ' + error.message);
            } finally {
                btn.disabled = false;
                btn.innerHTML = originalText;
            }
        }

        function getTimeAgo(date) {
            const now = new Date();
            const diff = now - date;
            const minutes = Math.floor(diff / 60000);
            const hours = Math.floor(diff / 3600000);
            const days = Math.floor(diff / 86400000);

            if (days > 0) return `${days}d ago`;
            if (hours > 0) return `${hours}h ago`;
            if (minutes > 0) return `${minutes}m ago`;
            return 'Just now';
        }

        function showSuccess(message) {
            // Simple success message (you can enhance this with a toast)
            console.log('✅', message);
            alert('Success: ' + message);
        }

        function showError(message) {
            // Simple error message (you can enhance this with a toast)
            console.error('❌', message);
            alert('Error: ' + message);
        }

        // Initialize when page loads
        document.addEventListener('DOMContentLoaded', function () {
            console.log('Admin dashboard initializing...');

            // Initialize push notification service
            if (typeof PushNotificationService !== 'undefined') {
                window.pushNotificationService = new PushNotificationService();
                window.pushNotificationService.initialize().then(() => {
                    console.log('Push notification service initialized');
                }).catch(error => {
                    console.error('Failed to initialize push notifications:', error);
                });
            }

            // Initialize notification poller
            if (typeof AdminNotificationPoller !== 'undefined') {
                window.notificationPoller = new AdminNotificationPoller();
                window.notificationPoller.start();
                console.log('Notification poller started');
            }

            // Load initial status
            loadSystemStatus();

            // Set up event listeners
            document.getElementById('quick-health-check').addEventListener('click', runQuickHealthCheck);
            document.getElementById('refresh-status').addEventListener('click', loadSystemStatus);
            document.getElementById('test-notification').addEventListener('click', testNotification);
            document.getElementById('test-notification-system').addEventListener('click', testNotificationSystem);

            // Auto-refresh status every 2 minutes
            const refreshInterval = setInterval(loadSystemStatus, 120000);
            console.log('Auto-refresh interval set to 2 minutes');

            // Store interval ID for cleanup
            window.systemStatusInterval = refreshInterval;
        });
    </script>
</AdminLayout>
