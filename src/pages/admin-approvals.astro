---
import AdminLayout from '../components/AdminLayout.astro';
---
<AdminLayout title="Review Submissions" activeNav="admin-approvals.html" breadcrumbSection="Overview" breadcrumbPage="Review Submissions">
  <Fragment slot="head">
    <script is:inline src="/js/admin-approvals-enhanced.js?v=2"></script>
    <script is:inline src="/js/main.js"></script>
  </Fragment>

<div class="max-w-7xl mx-auto px-4 sm:px-8 py-8 md:py-12">
            
            <div class="flex items-end justify-between mb-8">
                <div>
                    <h1 class="font-display font-black tracking-wide text-3xl md:text-4xl text-white uppercase mb-2">Review Submissions</h1>
                    <p class="text-gray-400">Approve or reject pending events and venues.</p>
                </div>
            </div>

            <!-- Enhanced Dashboard Stats Bar -->
            <div class="grid grid-cols-1 md:grid-cols-4 gap-4 mb-8">
                <div class="bg-[#111] border border-white/5 shadow-sm  rounded-xl p-4 relative overflow-hidden">
                    <div class="absolute inset-0 bg-gradient-to-r from-purple-500/10 to-pink-500/10"></div>
                    <div class="relative flex items-center justify-between">
                        <div>
                            <p class="text-gray-400 text-sm font-medium">Total Pending</p>
                            <p class="text-3xl font-bold text-white" id="total-pending-count">-</p>
                            <p class="text-xs text-gray-500 mt-1">Items awaiting review</p>
                        </div>
                        <div class="text-4xl text-purple-400">
                            <i class="fas fa-clock"></i>
                        </div>
                    </div>
                </div>
                
                <div class="bg-[#111] border border-white/5 shadow-sm  rounded-xl p-4 relative overflow-hidden">
                    <div class="absolute inset-0 bg-gradient-to-r from-blue-500/10 to-cyan-500/10"></div>
                    <div class="relative flex items-center justify-between">
                        <div>
                            <p class="text-gray-400 text-sm font-medium">Events</p>
                            <p class="text-3xl font-bold text-white" id="pending-events-count">-</p>
                            <p class="text-xs text-gray-500 mt-1">Event submissions</p>
                        </div>
                        <div class="text-4xl text-blue-400">
                            <i class="fas fa-calendar"></i>
                        </div>
                    </div>
                </div>
                
                <div class="bg-[#111] border border-white/5 shadow-sm  rounded-xl p-4 relative overflow-hidden">
                    <div class="absolute inset-0 bg-gradient-to-r from-green-500/10 to-emerald-500/10"></div>
                    <div class="relative flex items-center justify-between">
                        <div>
                            <p class="text-gray-400 text-sm font-medium">Venues</p>
                            <p class="text-3xl font-bold text-white" id="pending-venues-count">-</p>
                            <p class="text-xs text-gray-500 mt-1">Venue submissions</p>
                        </div>
                        <div class="text-4xl text-green-400">
                            <i class="fas fa-map-marker-alt"></i>
                        </div>
                    </div>
                </div>
                
                <div class="bg-[#111] border border-white/5 shadow-sm  rounded-xl p-4 relative overflow-hidden">
                    <div class="absolute inset-0 bg-gradient-to-r from-orange-500/10 to-red-500/10"></div>
                    <div class="relative flex items-center justify-between">
                        <div>
                            <p class="text-gray-400 text-sm font-medium">Recurring</p>
                            <p class="text-3xl font-bold text-white" id="recurring-events-count">-</p>
                            <p class="text-xs text-gray-500 mt-1">Series events</p>
                        </div>
                        <div class="text-4xl text-orange-400">
                            <i class="fas fa-redo"></i>
                        </div>
                    </div>
                </div>
            </div>
            
            <!-- Enhanced Filters and Actions -->
            <div class="bg-[#0A0A0A] border border-white/5 rounded-xl p-6 mb-8 shadow-sm">
                <div class="flex flex-col lg:flex-row justify-between items-start lg:items-center gap-6">
                    <!-- Filter Section -->
                    <div class="flex flex-col sm:flex-row gap-4">
                        <div>
                            <label class="block text-sm font-medium text-gray-400 mb-2">Filter by Type</label>
                            <div class="flex flex-wrap gap-2">
                                <button id="filter-all" class="filter-btn active px-4 py-2 rounded-lg text-sm font-semibold transition-all duration-200">
                                    <i class="fas fa-list mr-2"></i>All Items
                                </button>
                                <button id="filter-events" class="filter-btn px-4 py-2 rounded-lg text-sm font-semibold transition-all duration-200">
                                    <i class="fas fa-calendar mr-2"></i>Events Only
                                </button>
                                <button id="filter-venues" class="filter-btn px-4 py-2 rounded-lg text-sm font-semibold transition-all duration-200">
                                    <i class="fas fa-map-marker-alt mr-2"></i>Venues Only
                                </button>
                                <button id="filter-recurring" class="filter-btn px-4 py-2 rounded-lg text-sm font-semibold transition-all duration-200">
                                    <i class="fas fa-redo mr-2"></i>Recurring Only
                                </button>
                                <button id="filter-past-recurring" class="filter-btn px-4 py-2 rounded-lg text-sm font-semibold transition-all duration-200">
                                    <i class="fas fa-clock mr-2"></i>Past Recurring
                                </button>
                            </div>
                        </div>
                        
                        <div>
                            <label class="block text-sm font-medium text-gray-400 mb-2">Sort by</label>
                            <select id="sort-select" class="bg-gray-700 border border-gray-600 rounded-lg px-3 py-2 text-white text-sm focus:ring-2 focus:ring-purple-500 focus:border-transparent">
                                <option value="newest">Newest First</option>
                                <option value="oldest">Oldest First</option>
                                <option value="name">Name A-Z</option>
                                <option value="type">Type</option>
                            </select>
                        </div>
                    </div>
                    
                    <!-- Actions Section -->
                    <div class="flex flex-col sm:flex-row items-start sm:items-end gap-4">
                        <div class="flex items-center gap-4">
                            <div class="flex items-center gap-2">
                                <input type="checkbox" id="auto-refresh" class="rounded text-purple-500 focus:ring-purple-500 bg-gray-700 border-gray-600">
                                <label for="auto-refresh" class="text-sm text-gray-300">Auto-refresh</label>
                            </div>
                            <div class="flex items-center gap-2">
                                <input type="checkbox" id="compact-view" class="rounded text-purple-500 focus:ring-purple-500 bg-gray-700 border-gray-600">
                                <label for="compact-view" class="text-sm text-gray-300">Compact View</label>
                            </div>
                        </div>
                        
                        <div class="flex gap-2">
                            <button id="bulk-approve-btn" class="bg-green-600 hover:bg-green-700 text-white px-4 py-2 rounded-lg text-sm font-semibold transition-all duration-200 disabled:opacity-50 disabled:cursor-not-allowed" disabled>
                                <i class="fas fa-check-double mr-2"></i>Bulk Approve
                            </button>
                            <button id="refresh-btn" class="bg-purple-600 hover:bg-purple-700 text-white px-4 py-2 rounded-lg text-sm font-semibold transition-all duration-200">
                                <i class="fas fa-sync-alt mr-2"></i>Refresh
                            </button>
                        </div>
                    </div>
                </div>
                
                <!-- Search Bar -->
                <div class="mt-4">
                    <div class="relative">
                        <input type="text" id="search-input" placeholder="Search by name, description, or venue..." 
                               class="w-full bg-gray-700 border border-gray-600 rounded-lg pl-10 pr-4 py-2 text-white placeholder-gray-400 focus:ring-2 focus:ring-purple-500 focus:border-transparent">
                        <i class="fas fa-search absolute left-3 top-1/2 transform -translate-y-1/2 text-gray-400"></i>
                    </div>
                </div>
            </div>
            
            <div id="loading-state" class="text-center py-10">
                <div class="loader inline-block"></div>
                <p class="mt-4 text-gray-400">Loading pending items...</p>
            </div>

            <div id="approval-list" class="space-y-6"></div>
            <div id="no-items-message" class="hidden text-center card-bg p-12">
                <div class="mx-auto h-16 w-16 flex items-center justify-center rounded-full bg-gray-800 text-green-400"><i class="fas fa-check-circle fa-2x"></i></div>
                <h3 class="mt-4 text-xl font-semibold text-white">All Caught Up!</h3>
                <p class="mt-2 text-gray-400">There are no pending submissions to review.</p>
            </div>

<div id="edit-modal" class="fixed inset-0 modal-backdrop flex items-center justify-center p-4 z-50 hidden">
        <div class="modal-content rounded-2xl p-8 w-full max-w-5xl max-h-[90vh] overflow-y-auto">
            <div class="flex justify-between items-center mb-6">
                <h3 id="modal-title" class="font-anton text-3xl text-white">
                    <i class="fas fa-edit mr-3"></i>Edit Event
                </h3>
                <button id="close-modal-btn" class="text-gray-400 hover:text-white text-2xl transition-colors">
                    <i class="fas fa-times"></i>
                </button>
            </div>
            
            <form id="edit-form" class="space-y-8">
                <!-- Event Details Section -->
                <div class="space-y-6">
                    <h4 class="text-xl font-bold accent-color-secondary">
                        <i class="fas fa-calendar-plus mr-2"></i>Event Details
                    </h4>
                    
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div>
                            <label class="block text-sm font-medium text-gray-300 mb-2">
                                <i class="fas fa-tag mr-1"></i>Event Name
                            </label>
                            <input type="text" id="edit-name" name="name" class="form-input w-full px-4 py-3 rounded-lg text-white focus:outline-none" placeholder="Enter event name">
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-gray-300 mb-2">
                                <i class="fas fa-link mr-1"></i>Ticket Link (Optional)
                            </label>
                            <input type="url" id="edit-link" name="link" class="form-input w-full px-4 py-3 rounded-lg text-white focus:outline-none" placeholder="https://">
                        </div>
                    </div>
                    
                    <div>
                        <label class="block text-sm font-medium text-gray-300 mb-2">
                            <i class="fas fa-align-left mr-1"></i>Description
                        </label>
                        <textarea id="edit-description" name="description" rows="4" class="form-input w-full px-4 py-3 rounded-lg text-white focus:outline-none resize-none" placeholder="Describe your event in detail..."></textarea>
                    </div>
                    
                    <!-- Image Section -->
                    <div>
                        <label class="block text-sm font-medium text-gray-300 mb-2">
                            <i class="fas fa-image mr-1"></i>Event Image
                        </label>
                        <div class="space-y-4">
                            <!-- Current Image Display -->
                            <div id="current-image-container" class="hidden">
                                <p class="text-sm text-gray-400 mb-2">Current Image:</p>
                                <div class="relative inline-block">
                                    <img id="current-image" src="" alt="Current event image" class="w-48 h-32 object-cover rounded-lg border border-gray-600">
                                    <button type="button" id="remove-image-btn" class="absolute top-2 right-2 bg-red-600 hover:bg-red-700 text-white rounded-full w-6 h-6 flex items-center justify-center text-xs">
                                        <i class="fas fa-times"></i>
                                    </button>
                                </div>
                            </div>
                            
                            <!-- Image Upload -->
                            <div>
                                <input type="file" id="edit-image-upload" name="image" accept="image/*" class="hidden">
                                <button type="button" id="upload-image-btn" class="bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded-lg transition-colors">
                                    <i class="fas fa-upload mr-2"></i>Upload New Image
                                </button>
                                <p class="text-xs text-gray-400 mt-1">Click to upload a new image or remove the current one</p>
                            </div>
                        </div>
                    </div>
                    
                    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                        <div>
                            <label class="block text-sm font-medium text-gray-300 mb-2">
                                <i class="fas fa-calendar mr-1"></i>Date
                            </label>
                            <input type="date" id="edit-date" name="date" class="form-input w-full px-4 py-3 rounded-lg text-white focus:outline-none">
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-gray-300 mb-2">
                                <i class="fas fa-clock mr-1"></i>Time
                            </label>
                            <input type="time" id="edit-time" name="time" class="form-input w-full px-4 py-3 rounded-lg text-white focus:outline-none">
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-gray-300 mb-2">
                                <i class="fas fa-check-circle mr-1"></i>Status
                            </label>
                            <select id="edit-status" name="status" class="form-input w-full px-4 py-3 rounded-lg text-white focus:outline-none">
                                <option value="pending">Pending Review</option>
                                <option value="approved">Approved</option>
                                <option value="rejected">Rejected</option>
                            </select>
                        </div>
                    </div>
                    
                    <div>
                        <label class="block text-sm font-medium text-gray-300 mb-2">
                            <i class="fas fa-tags mr-1"></i>Categories
                        </label>
                        <div class="grid grid-cols-2 md:grid-cols-4 gap-3" id="edit-categories">
                            <!-- Categories will be populated dynamically -->
                        </div>
                    </div>
                </div>

                <!-- Venue Details Section -->
                <div class="space-y-6">
                    <h4 class="text-xl font-bold accent-color-secondary">
                        <i class="fas fa-map-marker-alt mr-2"></i>Venue Details
                    </h4>
                    
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div class="md:col-span-2">
                            <label class="block text-sm font-medium text-gray-300 mb-2">
                                <i class="fas fa-map-marker-alt mr-1"></i>Venue
                            </label>
                            <select id="edit-venue-select" name="venueId" class="form-input w-full px-4 py-3 rounded-lg text-white focus:outline-none">
                                <option value="">Select an existing venue...</option>
                                <option value="new">➕ Create New Venue</option>
                            </select>
                            <p class="text-xs text-gray-400 mt-1">Select an existing venue or choose "Create New Venue" below</p>
                        </div>
                    </div>

                    <!-- New Venue Fields (Hidden by default) -->
                    <div id="edit-new-venue-fields" class="hidden space-y-4 transition-all duration-300">
                        <div class="card-bg p-4 rounded-lg border border-blue-600/30">
                            <h5 class="text-blue-300 font-semibold mb-3">
                                <i class="fas fa-plus-circle mr-2"></i>Create New Venue
                            </h5>
                            <p class="text-sm text-blue-200 mb-4">Fill in the details for your new venue below.</p>
                            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                                <div>
                                    <label class="block text-sm font-medium text-gray-300 mb-2">Venue Name</label>
                                    <input type="text" id="edit-new-venue-name" class="form-input w-full px-4 py-3 rounded-lg text-white focus:outline-none" placeholder="Enter venue name">
                                </div>
                                <div>
                                    <label class="block text-sm font-medium text-gray-300 mb-2">Venue Address</label>
                                    <input type="text" id="edit-new-venue-address" class="form-input w-full px-4 py-3 rounded-lg text-white focus:outline-none" placeholder="Enter venue address">
                                </div>
                                <div>
                                    <label class="block text-sm font-medium text-gray-300 mb-2">Postcode</label>
                                    <input type="text" id="edit-new-venue-postcode" class="form-input w-full px-4 py-3 rounded-lg text-white focus:outline-none" placeholder="Enter postcode">
                                </div>
                                <div>
                                    <label class="block text-sm font-medium text-gray-300 mb-2">Website (Optional)</label>
                                    <input type="url" id="edit-new-venue-website" class="form-input w-full px-4 py-3 rounded-lg text-white focus:outline-none" placeholder="https://">
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Additional Fields Section -->
                <div class="space-y-6">
                    <h4 class="text-xl font-bold accent-color-secondary">
                        <i class="fas fa-cog mr-2"></i>Additional Details
                    </h4>
                    
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div>
                            <label class="block text-sm font-medium text-gray-300 mb-2">
                                <i class="fas fa-pound-sign mr-1"></i>Price
                            </label>
                            <input type="text" id="edit-price" name="price" class="form-input w-full px-4 py-3 rounded-lg text-white focus:outline-none" placeholder="Free, £10, etc.">
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-gray-300 mb-2">
                                <i class="fas fa-users mr-1"></i>Age Restriction
                            </label>
                            <input type="text" id="edit-age-restriction" name="ageRestriction" class="form-input w-full px-4 py-3 rounded-lg text-white focus:outline-none" placeholder="18+, All ages, etc.">
                        </div>
                    </div>
                </div>

                <!-- Form Actions -->
                <div class="flex justify-end gap-4 pt-6 border-t border-gray-700">
                    <button type="button" id="cancel-edit-btn" class="bg-gray-700 hover:bg-gray-600 text-white font-bold py-3 px-6 rounded-lg transition-colors">
                        <i class="fas fa-times mr-2"></i>Cancel
                    </button>
                    <button type="submit" class="bg-purple-600 hover:bg-purple-700 text-white font-bold py-3 px-6 rounded-lg transition-colors">
                        <i class="fas fa-save mr-2"></i>Save Changes
                    </button>
                </div>
            </form>
        </div>
    </div>

    <div id="rejection-modal" class="fixed inset-0 bg-black/80 backdrop-blur-sm flex items-center justify-center p-4 z-50 hidden">
        <div class="card-bg p-8 w-full max-w-lg">
            <h3 class="font-anton text-3xl text-white mb-4">Reason for Rejection</h3>
            <p class="text-gray-400 mb-6">This will be sent to the promoter if they provided an email. Keep it brief and helpful.</p>
            <textarea id="rejection-reason" rows="4" class="w-full p-3 bg-gray-900/50 rounded-lg border border-gray-700"></textarea>
            <div class="flex justify-end gap-4 mt-6">
                <button id="cancel-rejection-btn" class="bg-gray-700 text-white font-bold py-2 px-6 rounded-lg">Cancel</button>
                <button id="confirm-rejection-btn" class="bg-red-600 text-white font-bold py-2 px-6 rounded-lg">Confirm Rejection</button>
            </div>
        </div>
    </div>

    <div id="recurring-approval-modal" class="fixed inset-0 bg-black/80 backdrop-blur-sm flex items-center justify-center p-4 z-50 hidden">
        <div class="card-bg p-8 w-full max-w-lg">
            <h3 class="font-anton text-3xl text-white mb-4">Approve Recurring Event</h3>
            <p class="text-gray-400 mb-6">This is part of a recurring series. Choose how you want to handle the approval:</p>
            
            <div class="space-y-4 mb-6">
                <div class="flex items-start space-x-3 p-4 bg-gray-800/50 rounded-lg">
                    <input type="radio" id="approve-series" name="approval-type" value="series" class="mt-1" checked>
                    <div>
                        <label for="approve-series" class="font-semibold text-white">Approve entire series</label>
                        <p class="text-sm text-gray-400">Approve this instance and all future instances of this recurring event</p>
                    </div>
                </div>
                
                <div class="flex items-start space-x-3 p-4 bg-gray-800/50 rounded-lg">
                    <input type="radio" id="approve-single" name="approval-type" value="single" class="mt-1">
                    <div>
                        <label for="approve-single" class="font-semibold text-white">Approve this instance only</label>
                        <p class="text-sm text-gray-400">Approve only this specific event instance</p>
                    </div>
                </div>
            </div>
            
            <div class="flex justify-end gap-4">
                <button id="cancel-recurring-approval-btn" class="bg-gray-700 text-white font-bold py-2 px-6 rounded-lg">Cancel</button>
                <button id="confirm-recurring-approval-btn" class="bg-green-600 text-white font-bold py-2 px-6 rounded-lg">Confirm Approval</button>
            </div>
        </div>
    </div>
    
    <!-- Image Modal -->
    <div id="image-modal" class="fixed inset-0 bg-black/90 backdrop-blur-sm flex items-center justify-center p-4 z-50 hidden">
        <div class="relative max-w-4xl max-h-full">
            <div class="bg-gray-900 rounded-lg p-4">
                <div class="flex justify-between items-center mb-4">
                    <h3 id="modal-title" class="text-xl font-bold text-white"></h3>
                    <button class="close-modal text-gray-400 hover:text-white text-2xl">
                        <i class="fas fa-times"></i>
                    </button>
                </div>
                <img id="modal-image" src="" alt="" class="max-w-full max-h-96 object-contain rounded-lg">
            </div>
        </div>
    </div>


<script is:inline>
        // Mobile menu toggle
        document.querySelector('button.lg\\:hidden').addEventListener('click', function() {
            document.querySelector('aside').classList.toggle('hidden');
        });
    </script>
</AdminLayout>
