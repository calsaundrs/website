                            <span class="font-bold text-white uppercase">How do I get there?</span>
                            <span class="text-2xl text-[var(--color-toxic)] plus-icon font-bold">+</span>
                        </summary>
                        <p class="text-gray-200 mt-3">Birmingham New Street is the nearest station — short walk to Gay Village on Hurst Street. If driving, expect road closures. Multiple bus routes serve the centre.</p>
                    </details>

                    <details class="group border-b-2 border-gray-800 py-4 md:col-span-2">
                        <summary class="flex items-center justify-between cursor-pointer list-none">
                            <span class="font-bold text-white uppercase">Can I bring children?</span>
                            <span class="text-2xl text-[var(--color-toxic)] plus-icon font-bold">+</span>
                        </summary>
                        <p class="text-gray-200 mt-3">Under 12s go free (book online, bring ID for wristband). Under 18s must be with an adult at all times.</p>
                    </details>
                </div>
            </div>
        </section>

        <!-- Submit CTA — full-bleed accent band -->
        <section style="background: linear-gradient(135deg, var(--color-pink), var(--color-purple));">
            <div class="max-w-5xl mx-auto px-6 md:px-12 py-16 md:py-20 text-center">
                <h2 class="text-3xl sm:text-4xl md:text-5xl font-black text-white uppercase font-display misprint mb-4">Hosting a Pride Event?</h2>
                <p class="text-white/80 text-lg mb-8 max-w-xl mx-auto">Running a Pride afterparty, brunch, viewing party, or any LGBTQ+ event during Pride weekend? Submit it and we'll list it here.</p>
                <a href="/promoter-submit-new" class="sticker bg-white !text-black text-lg hover:bg-[var(--color-toxic)] transition-colors"><i class="fas fa-plus-circle mr-2"></i>SUBMIT YOUR PRIDE EVENT</a>
            </div>
        </section>

    </main>

  <Fragment slot="scripts">
    <script is:inline>
      // Mobile menu
      const menuBtn = document.getElementById('menu-btn');
      const menu = document.getElementById('menu');
      if (menuBtn && menu) {
        menuBtn.addEventListener('click', () => {
          menu.classList.toggle('hidden');
          menu.classList.toggle('flex');
        });
      }

      // Dynamic Pride events loader
      async function loadPrideEvents() {
        const grid = document.getElementById('pride-events-grid');
        const empty = document.getElementById('pride-events-empty');
        try {
          const res = await fetch('/.netlify/functions/get-events');
          if (!res.ok) throw new Error(res.status);
          const data = await res.json();
          const events = Array.isArray(data.events) ? data.events : (Array.isArray(data) ? data : []);

          const prideEvents = events.filter(e => {
            const date = e.date || e.startDate || '';
            return date >= '2026-05-18' && date <= '2026-05-25';
          }).slice(0, 6);

          if (prideEvents.length === 0) {
            grid.style.display = 'none';
            empty.classList.remove('hidden');
            return;
          }

          grid.innerHTML = prideEvents.map(e => {
            const name = e.name || e.title || 'Pride Event';
            const date = e.date || e.startDate || '';
            const venue = e.venueName || (e.venue && e.venue.name) || '';
            const image = (e.image && e.image.url) ? e.image.url : (e.image || e.imageUrl || e.flyer || '');
            const slug = e.slug || '';
            const href = slug ? '/event/' + slug : '/events';
            const dateStr = date ? new Date(date).toLocaleDateString('en-GB', { weekday: 'short', day: 'numeric', month: 'short', timeZone: 'UTC' }) : '';

            const imgHTML = image
              ? '<div class="w-full h-40 overflow-hidden border-b-2 border-gray-800"><img src="' + image + '" alt="" class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-105"></div>'
              : '';

            return '<a href="' + href + '" class="pride-event-card group">'
              + imgHTML
              + '<div class="p-6 flex flex-col flex-grow">'
              + '<p class="text-white font-bold uppercase font-display leading-tight mb-2">' + name + '</p>'
              + (dateStr ? '<p class="text-[var(--color-toxic)] text-sm font-bold mt-auto"><i class="fas fa-calendar-day mr-1"></i>' + dateStr + '</p>' : '')
              + (venue ? '<p class="text-gray-300 text-sm mt-1"><i class="fas fa-map-marker-alt mr-1 text-[var(--color-pink)]"></i>' + venue + '</p>' : '')
              + '</div></a>';
          }).join('');
        } catch (err) {
          console.log('Could not load Pride events:', err);
          grid.style.display = 'none';
          empty.classList.remove('hidden');
        }
      }
      document.addEventListener('DOMContentLoaded', loadPrideEvents);

      // Roll year forward after the festival ends each year
      document.addEventListener('DOMContentLoaded', () => {
        const d = new Date();
        let year = d.getFullYear();
        if (d.getMonth() > 4) year += 1;
        document.querySelectorAll('span.current-year').forEach(el => { el.textContent = year; });
      });
    </script>
  </Fragment>
</PublicLayout>
