---
import PublicLayout from '../components/PublicLayout.astro';

const eventSchema = {
  '@context': 'https://schema.org',
  '@type': 'Event',
  name: 'Birmingham Pride 2026',
  description: 'The official guide to Birmingham Pride 2026 in the West Midlands. Featuring a massive city centre parade, multi-stage music festival in the Gay Village, and celebrations across Hurst Street.',
  startDate: '2026-05-22T18:00:00+01:00',
  endDate: '2026-05-24T23:59:59+01:00',
  eventStatus: 'https://schema.org/EventScheduled',
  eventAttendanceMode: 'https://schema.org/OfflineEventAttendanceMode',
  location: {
    '@type': 'Place',
    name: 'Gay Village, Birmingham',
    address: {
      '@type': 'PostalAddress',
      addressLocality: 'Birmingham',
      addressRegion: 'West Midlands',
      postalCode: 'B5 4TD',
      addressCountry: 'GB',
    },
    geo: {
      '@type': 'GeoCoordinates',
      latitude: 52.4744,
      longitude: -1.8958,
    },
  },
  image: ['https://birminghampride.com/wp-content/uploads/2025/02/pride-montage@4x-1024x930.png'],
  organizer: {
    '@type': 'Organization',
    name: 'Birmingham Pride',
    url: 'https://birminghampride.com',
    logo: 'https://birminghampride.com/wp-content/uploads/2025/07/Pride25__Birmingham-signpost_Stacked_COL-1024x267.png',
  },
  offers: {
    '@type': 'AggregateOffer',
    url: 'https://birminghampride.com',
    priceCurrency: 'GBP',
    lowPrice: '0',
    availability: 'https://schema.org/InStock',
    validFrom: '2025-12-01T00:00:00Z',
  },
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'When is Birmingham Pride 2026?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Friday 22 May (free community evening), then the main festival runs Saturday 23 May and Sunday 24 May 2026 in the Gay Village. Ticketed stages open across the weekend.',
      },
    },
    {
      '@type': 'Question',
      name: 'Is the Birmingham Pride parade free to attend?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Yes, the Birmingham Pride parade is completely free to watch. It starts at 12 noon on Saturday 23rd May from Centenary Square.',
      },
    },
    {
      '@type': 'Question',
      name: 'Where is the Gay Village in Birmingham?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'The Birmingham Gay Village is located in Southside, centred around Hurst Street, just a short walk from New Street Station.',
      },
    },
  ],
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://www.brumoutloud.co.uk/' },
    { '@type': 'ListItem', position: 2, name: 'Birmingham Pride', item: 'https://www.brumoutloud.co.uk/birmingham-pride' },
  ],
};

const organizationSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'Birmingham Pride',
  url: 'https://birminghampride.com',
  logo: 'https://birminghampride.com/wp-content/uploads/2025/07/Pride25__Birmingham-signpost_Stacked_COL-1024x267.png',
};
---
<PublicLayout
  title="Birmingham Pride 2026 | Dates, Lineup & Guide | Brum Outloud"
  description="Your complete guide to Birmingham Pride 2026 — 22-24 May. Parade route, stage lineup, tickets, accessibility info and accommodation."
  canonical="https://www.brumoutloud.co.uk/birmingham-pride"
  ogImage="https://birminghampride.com/wp-content/uploads/2025/02/pride-montage@4x-1024x930.png"
  ogImageWidth={1024}
  ogImageHeight={930}
  jsonLd={[eventSchema, faqSchema, breadcrumbSchema, organizationSchema]}
>
  <Fragment slot="head">
    <style>
        body {
            background: var(--color-bg);
            color: var(--color-light);
            font-family: 'Space Grotesk', system-ui, sans-serif;
            min-height: 100vh;
            margin: 0;
        }
        .font-display { font-family: 'Syne', sans-serif; }
        .misprint { letter-spacing: -0.03em; line-height: 0.95; overflow-wrap: break-word; word-break: break-word; }

        .noise-overlay {
            position: fixed;
            inset: 0;
            background: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noiseFilter)' opacity='0.03'/%3E%3C/svg%3E");
            pointer-events: none;
            z-index: 9999;
            mix-blend-mode: overlay;
        }

        .glass-panel {
            background: var(--color-bg);
            border-bottom: 2px solid var(--color-pink);
        }

        /* Animations */
        @keyframes fade-in-up {
            from { opacity: 0; transform: translateY(30px); }
            to { opacity: 1; transform: translateY(0); }
        }
        .animate-fade-in-up {
            animation: fade-in-up 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
            opacity: 0;
        }
        .delay-100 { animation-delay: 100ms; }
        .delay-200 { animation-delay: 200ms; }
        
        .hover-lift {
            transition: transform 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275), box-shadow 0.4s ease;
        }
        .hover-lift:hover {
            transform: translateY(-4px) scale(1.02);
        }

        

        

        /* Section blocks */
        .content-block {
            border: 4px solid var(--color-light);
            box-shadow: 6px 6px 0 var(--color-purple);
            background: #000;
            padding: 2rem;
            margin-bottom: 2rem;
        }
        @media (min-width: 768px) { .content-block { padding: 2.5rem; } }

        /* Hero image */
        .hero-image {
            position: relative;
        }
        .hero-image img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            filter: contrast(1.1) saturate(1.2);
            transition: filter 0.5s ease, transform 0.5s ease;
        }
        .hero-image:hover img {
            filter: contrast(1.2) saturate(1.3);
            transform: scale(1.02);
        }

        /* Lineup cards */
        .lineup-card {
            border-radius: 0;
            background: #150A20;
            border: 2px solid #331A40;
            text-align: center;
            font-weight: 800;
            text-transform: uppercase;
            font-family: 'Syne', sans-serif;
            transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            overflow: hidden;
            position: relative;
            box-shadow: 0 4px 20px rgba(0,0,0,0.5);
        }
        .lineup-card::before {
            content: '';
            position: absolute;
            inset: 0;
            border-radius: 8px;
            padding: 3px;
            background: linear-gradient(45deg, transparent, transparent);
            -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
            mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
            -webkit-mask-composite: xor;
            mask-composite: exclude;
            pointer-events: none;
            transition: background 0.4s ease;
        }
        .lineup-card:hover {
            transform: translateY(-6px) scale(1.03) rotate(1deg);
            box-shadow: 0 15px 30px rgba(155, 93, 229, 0.3);
            z-index: 10;
        }
        .lineup-card:hover::before {
            background: linear-gradient(135deg, var(--color-pink), var(--color-toxic), var(--color-purple));
        }
        .lineup-card-img {
            width: 100%;
            aspect-ratio: 1;
            object-fit: cover;
            filter: contrast(1.1) saturate(1.1);
            transition: filter 0.3s ease, transform 0.3s ease;
            display: block;
        }
        .lineup-card:hover .lineup-card-img {
            filter: contrast(1.2) saturate(1.2);
            transform: scale(1.05);
        }
        .lineup-card-name {
            padding: 0.5rem 0.4rem;
            font-size: 0.8rem;
            line-height: 1.1;
            color: var(--color-light);
        }
        .lineup-card-text {
            padding: 1.25rem 0.5rem;
            font-size: 0.8rem;
            color: var(--color-light);
        }
        /* Headliner badge strip */
        .lineup-headliner-badge {
            background: var(--color-pink);
            color: #fff;
            font-size: 0.6rem;
            font-weight: 800;
            letter-spacing: 0.12em;
            padding: 0.2rem 0;
            text-align: center;
            display: block;
        }
        /* Day header */
        .lineup-day-header {
            display: flex;
            align-items: baseline;
            gap: 1rem;
            margin-bottom: 1rem;
            padding-bottom: 0.75rem;
            border-bottom: 3px solid var(--color-toxic);
        }

        /* Set-time prefix on the Dance Arena + Cabaret Stage schedules.
           Tabular figures keep the column aligned between 14:00 / 19:30
           / 23:00 without juggling Tailwind w-N classes per row. */
        .schedule-time {
            display: inline-block;
            width: 3.5rem;
            color: var(--color-toxic);
            font-weight: 700;
            font-variant-numeric: tabular-nums;
        }

        /* Bento lineup grid — 4 cols, headliners span 2×2 */
        .lineup-bento {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 0.5rem;
        }
        .lineup-bento .lineup-card-headliner {
            grid-column: span 2;
            grid-row: span 2;
        }
        .lineup-bento .lineup-card-headliner .lineup-card-img {
            aspect-ratio: auto;
            height: 100%;
            min-height: 280px;
        }
        .lineup-bento .lineup-card-headliner .lineup-headliner-badge {
            font-size: 0.7rem;
            padding: 0.3rem 0;
            border-radius: 6px 6px 0 0;
        }
        @media (max-width: 767px) {
            .lineup-bento { grid-template-columns: repeat(2, 1fr); }
            .lineup-bento .lineup-card-headliner .lineup-card-img { min-height: 200px; }
        }

        /* Venue cards — glassmorphism */
        .venue-block {
            border: 2px solid var(--color-purple);
            background: #0a0a0a;
            border-radius: 0;
            box-shadow: 4px 4px 0 rgba(155, 93, 229, 0.3);
            transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
            overflow: hidden;
        }
        .venue-block:hover {
            background: rgba(255, 255, 255, 0.08);
            border-color: rgba(232, 58, 153, 0.5);
            transform: translateY(-4px);
            box-shadow: 0 10px 30px rgba(0,0,0,0.5), 0 0 20px rgba(155, 93, 229, 0.2);
        }
        .venue-block-img {
            width: 100%;
            height: 160px;
            object-fit: cover;
            filter: contrast(1.1) saturate(1.1);
            transition: filter 0.3s ease;
            display: block;
        }
        .venue-block:hover .venue-block-img {
            filter: contrast(1.2) saturate(1.2);
        }
        .venue-block-info {
            padding: 1.25rem;
        }

        /* Route */
        .route-dot {
            width: 14px; height: 14px;
            border-radius: 0;
            background: var(--color-toxic);
            flex-shrink: 0;
        }
        .route-dot.end { background: var(--color-pink); }
        .route-line { width: 4px; height: 1.5rem; background: rgba(204, 255, 0, 0.2); margin-left: 5px; }

        /* Section divider */
        .section-divider {
            height: 6px;
            background: repeating-linear-gradient(45deg, var(--color-toxic), var(--color-toxic) 10px, #000 10px, #000 20px);
        }

        /* Key fact boxes */
        .key-fact {
            border: 2px solid var(--color-toxic);
            background: #000;
            border-radius: 0;
            box-shadow: 4px 4px 0 rgba(204, 255, 0, 0.3);
            padding: 1.5rem;
            text-align: center;
            transition: transform 0.3s ease, border-color 0.3s ease;
        }
        .key-fact:hover {
            transform: translateY(-2px);
            border-color: var(--color-toxic);
        }

        /* FAQ */
        details summary::-webkit-details-marker { display: none; }
        details .plus-icon { transition: transform 0.2s ease-in-out; }
        details[open] .plus-icon { transform: rotate(45deg); }

        /* Event cards for dynamic section */
        .pride-event-card {
            border: 2px solid #333;
            background: #000;
            border-radius: 0;
            box-shadow: 4px 4px 0 #333;
            padding: 0;
            transition: all 0.4s ease;
            display: flex;
            flex-direction: column;
            text-decoration: none;
            color: inherit;
            overflow: hidden;
        }
        .pride-event-card:hover {
            border-color: rgba(232, 58, 153, 0.5);
            background: rgba(255, 255, 255, 0.05);
            transform: translateY(-4px);
            box-shadow: 6px 10px 0 var(--color-pink);
        }

        /* Marquee ticker */
        .marquee-strip {
            overflow: hidden;
            white-space: nowrap;
            background: var(--color-toxic);
            color: #000;
            font-family: 'Syne', sans-serif;
            font-weight: 800;
            font-size: 0.8rem;
            letter-spacing: 0.2em;
            text-transform: uppercase;
            padding: 0.6rem 0;
            user-select: none;
        }
        .marquee-inner {
            display: inline-block;
            animation: marquee-scroll 30s linear infinite;
        }
        @keyframes marquee-scroll {
            0% { transform: translateX(0); }
            100% { transform: translateX(-50%); }
        }
    </style>
  </Fragment>

  <div class="watermark-bg text-[var(--color-pink)]">PRIDE</div>
  <div class="noise-overlay"></div>

    <!-- Hero — full-bleed gradient background -->
    <section class="relative overflow-hidden" style="background: linear-gradient(135deg, #0d0115 0%, #1a0a2e 50%, #0d0115 100%);">
        <div class="max-w-7xl mx-auto px-6 md:px-12 pt-16 pb-12 lg:grid lg:grid-cols-5 lg:gap-8 lg:items-center">
            <!-- Left: heading + subtext + CTA -->
            <div class="lg:col-span-3 relative z-10 animate-fade-in-up">
                <div class="sticker bg-[var(--color-pink)] text-white text-sm mb-6 drop-shadow-md">YOUR ULTIMATE GUIDE</div>
                <h1 class="text-5xl sm:text-6xl md:text-7xl lg:text-8xl font-black text-white uppercase font-display leading-[0.85] mb-6 drop-shadow-[0_10px_40px_rgba(0,0,0,0.8)]" style="letter-spacing: -0.03em;">Birmingham<br>Pride <span class="text-[var(--color-toxic)] opacity-90 drop-shadow-[0_0_30px_rgba(204,255,0,0.3)]">2026</span></h1>
                <p class="text-gray-200 text-lg md:text-xl md:pr-10 mb-8 leading-relaxed">One of the UK's largest LGBTQ+ festivals returns. Three days of explosive celebration — free community kick-off Friday, the massive Saturday parade, and the epic Gay Village festival Saturday–Sunday. Yes babs, let's glow!</p>
                <div class="flex flex-col sm:flex-row gap-4 items-start sm:items-center mb-8">
                    <a href="https://birminghampride.com" target="_blank" rel="noopener noreferrer" class="sticker bg-[var(--color-toxic)] !text-black text-lg hover:bg-white transition-all duration-300 hover:scale-[1.03] shadow-[0_0_20px_rgba(204,255,0,0.3)]"><i class="fas fa-ticket-alt mr-2"></i>BUY TICKETS</a>
                    <span class="text-gray-300 text-sm italic">Parade is free. Under 12s free.</span>
                </div>
                <!-- Quick Jump Links -->
                <div class="flex flex-wrap gap-2 mt-2">
                    <a href="#about" class="text-xs font-bold uppercase tracking-widest text-white bg-transparent border-2 border-white px-4 py-2 hover:bg-[var(--color-toxic)] hover:border-[var(--color-toxic)] hover:text-black transition-all duration-300">About</a>
                    <a href="#first-time" class="text-xs font-bold uppercase tracking-widest text-white bg-transparent border-2 border-white px-4 py-2 hover:bg-[var(--color-toxic)] hover:border-[var(--color-toxic)] hover:text-black transition-all duration-300">First Timer?</a>
                    <a href="#parade" class="text-xs font-bold uppercase tracking-widest text-white bg-transparent border-2 border-white px-4 py-2 hover:bg-[var(--color-toxic)] hover:border-[var(--color-toxic)] hover:text-black transition-all duration-300">Parade</a>
                    <a href="#lineup" class="text-xs font-bold uppercase tracking-widest text-white bg-transparent border-2 border-white px-4 py-2 hover:bg-[var(--color-toxic)] hover:border-[var(--color-toxic)] hover:text-black transition-all duration-300">Lineup</a>
                    <a href="#venues" class="text-xs font-bold uppercase tracking-widest text-white bg-transparent border-2 border-white px-4 py-2 hover:bg-[var(--color-toxic)] hover:border-[var(--color-toxic)] hover:text-black transition-all duration-300">Venues</a>
                    <a href="#tickets" class="text-xs font-bold uppercase tracking-widest text-white bg-transparent border-2 border-white px-4 py-2 hover:bg-[var(--color-toxic)] hover:border-[var(--color-toxic)] hover:text-black transition-all duration-300">FAQ</a>
                </div>
            </div>
            <!-- Right: hero image (transparent bg, no frame) -->
            <div class="mt-12 lg:mt-0 lg:col-span-2 relative animate-fade-in-up delay-200">
                <div class="absolute inset-0 bg-[var(--color-pink)] blur-[100px] opacity-20 rounded-full animate-pulse z-0"></div>
                <img src="https://res.cloudinary.com/dbxhpjoiz/image/fetch/f_auto,q_auto,w_1024/https://birminghampride.com/wp-content/uploads/2025/02/pride-montage@4x-1024x930.png" alt="Birmingham Pride parade and festival celebration montage" width="1024" height="930" loading="eager" fetchpriority="high" decoding="sync" class="w-full h-auto relative z-10 hover-lift" style="max-height: 550px; object-fit: contain; filter: drop-shadow(0 10px 40px rgba(232,58,153,0.4));">
            </div>
        </div>
        <!-- Key Facts bar -->
        <div class="border-t border-b border-gray-800" style="background: rgba(255,255,255,0.03);">
            <div class="max-w-7xl mx-auto px-6 md:px-12 grid grid-cols-2 md:grid-cols-4 gap-0 divide-x divide-gray-800">
                <div class="py-5 px-4 text-center">
                    <p class="text-[var(--color-toxic)] font-bold text-xs uppercase tracking-widest mb-1">Dates</p>
                    <p class="text-white font-black text-lg font-display">22 – 24 MAY</p>
                    <p class="text-gray-300 text-sm">Fri (free) · Sat · Sun</p>
                </div>
                <div class="py-5 px-4 text-center">
                    <p class="text-[var(--color-toxic)] font-bold text-xs uppercase tracking-widest mb-1">Location</p>
                    <p class="text-white font-black text-lg font-display">GAY VILLAGE</p>
                    <p class="text-gray-300 text-sm">Hurst Street, Birmingham</p>
                </div>
                <div class="py-5 px-4 text-center">
                    <p class="text-[var(--color-toxic)] font-bold text-xs uppercase tracking-widest mb-1">Parade</p>
                    <p class="text-white font-black text-lg font-display">SAT 12 NOON</p>
                    <p class="text-gray-300 text-sm">FREE — no ticket needed</p>
                </div>
                <div class="py-5 px-4 text-center">
                    <p class="text-[var(--color-toxic)] font-bold text-xs uppercase tracking-widest mb-1">Tickets</p>
                    <p class="text-white font-black text-lg font-display">ON SALE NOW</p>
                    <p class="text-gray-300 text-sm">Under 12s go free</p>
                </div>
            </div>
        </div>
    </section>

    <!-- Marquee ticker -->
    <div class="marquee-strip">
        <div class="marquee-inner">&nbsp;· BIRMINGHAM PRIDE 2026 &nbsp;· FRI 22 MAY (FREE) &nbsp;· SAT 23 MAY &nbsp;· SUN 24 MAY &nbsp;· GAY VILLAGE HURST STREET &nbsp;· PARADE FREE · 12 NOON &nbsp;· 29 YEARS &amp; COUNTING &nbsp;· 75,000+ PARADE-GOERS &nbsp;· KATY B · SIGALA · DANNY BEARD · NADINE COYLE · BJORN AGAIN · BONEY M &nbsp;· BIRMINGHAM PRIDE 2026 &nbsp;· FRI 22 MAY (FREE) &nbsp;· SAT 23 MAY &nbsp;· SUN 24 MAY &nbsp;· GAY VILLAGE HURST STREET &nbsp;· PARADE FREE · 12 NOON &nbsp;· 29 YEARS &amp; COUNTING &nbsp;· 75,000+ PARADE-GOERS &nbsp;· KATY B · SIGALA · DANNY BEARD · NADINE COYLE · BJORN AGAIN · BONEY M &nbsp;</div>
    </div>

    <main>

        <!-- AEO Answer Box -->
        <section class="max-w-7xl mx-auto px-6 md:px-12 pt-12">
            <div class="aeo-glass-card p-6 md:p-8 relative overflow-hidden group max-w-4xl">
                <div class="absolute top-0 left-0 w-full h-1 progress-pride-bg"></div>
                <div class="sticker bg-[var(--color-toxic)] !text-black text-xs mb-4 mt-2 inline-block">AEO SYNOPSIS</div>
                <p class="text-white text-lg font-bold mb-2">Birmingham Pride 2026 takes place 22-24 May. The parade starts at noon on Saturday from Centenary Square — it's free to watch.</p>
                <p class="text-gray-300">The main festival runs Saturday and Sunday in the Gay Village on Hurst Street. Tickets available from <a href="https://birminghampride.com" target="_blank" rel="noopener noreferrer" class="text-[var(--color-pink)] font-bold hover:text-white">birminghampride.com</a>. Under 12s go free. See our full guide below for lineup, venues, transport, and accessibility info.</p>
            </div>
        </section>

        <!-- What is Birmingham Pride? — open editorial layout -->
        <section id="about" class="max-w-7xl mx-auto px-6 md:px-12 py-16 md:py-24">
            <h2 class="text-3xl sm:text-4xl md:text-5xl font-black text-white uppercase font-display misprint mb-8" style="border-left: 6px solid var(--color-toxic); padding-left: 1rem;">What is Birmingham Pride?</h2>
            <div class="lg:grid lg:grid-cols-5 lg:gap-12 lg:items-start">
                <div class="text-gray-300 text-base md:text-lg space-y-5 leading-relaxed lg:col-span-3">
                    <p>Birmingham Pride is one of the UK's biggest and most vibrant LGBTQ+ Pride festivals. Established in <strong class="text-white">1997</strong>, the 2026 edition marks its <strong class="text-white">29th year</strong> celebrating queer life, equality, and community in the heart of England's second city.</p>
                    <p>The weekend kicks off on <strong class="text-white">Friday 22 May</strong> with a free community evening — dance party, drag showcase, no ticket price. Then the massive <strong class="text-white">parade through the city centre</strong> on Saturday morning, followed by a multi-stage music festival in Birmingham's famous <strong class="text-white">Gay Village on Hurst Street</strong> all weekend long. With over <strong class="text-white">75,000 spectators</strong> lining the parade route and around <strong class="text-white">40,000 festival-goers</strong> over the weekend, it's one of the biggest Pride celebrations outside London.</p>
                    <p>Whether you're a regular or visiting for the first time, this guide has everything you need to plan your Pride weekend.</p>
                </div>
                <div class="mt-8 lg:mt-0 lg:col-span-2">
                    <div class="border-4 border-[var(--color-light)] overflow-hidden" style="box-shadow: 6px 6px 0 var(--color-pink);">
                        <img src="https://res.cloudinary.com/dbxhpjoiz/image/fetch/f_auto,q_auto,w_1024/https://birminghampride.com/wp-content/uploads/2025/07/Pride25__Birmingham-signpost_Stacked_COL-1024x267.png" alt="Birmingham Pride 2025 signpost branding" width="1024" height="267" loading="lazy" decoding="async" class="w-full h-auto" 2025 Pride signpost>
                    </div>
                </div>
            </div>
        </section>

        <!-- First Time? — full-bleed tinted background -->
        <section id="first-time" style="background: linear-gradient(180deg, rgba(155,93,229,0.08) 0%, rgba(232,58,153,0.06) 100%);">
            <div class="max-w-7xl mx-auto px-6 md:px-12 py-16 md:py-24">
                <h2 class="text-3xl sm:text-4xl md:text-5xl font-black text-white uppercase font-display misprint mb-4" style="border-left: 6px solid var(--color-pink); padding-left: 1rem;">First Time at Pride?</h2>
                <p class="text-gray-300 text-base md:text-lg mb-10 max-w-3xl">Whether you're newly out, still questioning, or just visiting Birmingham for the first time — you're welcome here. No gatekeeping, no dress code, no expectations.</p>
                <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
                    <div class="border-l-4 border-[var(--color-pink)] pl-5">
                        <h3 class="text-white font-bold text-sm uppercase mb-2"><i class="fas fa-heart text-[var(--color-pink)] mr-2"></i>You don't have to be "out"</h3>
                        <p class="text-gray-200 text-sm leading-relaxed">Plenty of people come to Pride as allies, with friends, or just to check the vibe. Nobody's going to ask you to explain yourself. Come as you are.</p>
                    </div>
                    <div class="border-l-4 border-[var(--color-toxic)] pl-5">
                        <h3 class="text-white font-bold text-sm uppercase mb-2"><i class="fas fa-user text-[var(--color-toxic)] mr-2"></i>Coming alone is fine</h3>
                        <p class="text-gray-200 text-sm leading-relaxed">Loads of people do. The parade is a great place to join in — you'll be surrounded by people. Venue staff in the Gay Village are friendly and used to solo visitors.</p>
                    </div>
                    <div class="border-l-4 border-[var(--color-purple)] pl-5">
                        <h3 class="text-white font-bold text-sm uppercase mb-2"><i class="fas fa-tshirt text-[var(--color-purple)] mr-2"></i>Wear whatever you want</h3>
                        <p class="text-gray-200 text-sm leading-relaxed">Rainbow flag? Go for it. Normal clothes? Also fine. Drag? Incredible. There's no right way to do Pride. Comfy shoes are a good shout though — the parade is 1.5 miles.</p>
                    </div>
                    <div class="border-l-4 border-[var(--color-toxic)] pl-5">
                        <h3 class="text-white font-bold text-sm uppercase mb-2"><i class="fas fa-shield-alt text-[var(--color-toxic)] mr-2"></i>It's safe</h3>
                        <p class="text-gray-200 text-sm leading-relaxed">Birmingham Pride has dedicated safety teams, welfare tents, and police liaison officers. The Gay Village is a well-established safe space. If anything feels off, speak to any steward.</p>
                    </div>
                    <div class="border-l-4 border-[var(--color-purple)] pl-5">
                        <h3 class="text-white font-bold text-sm uppercase mb-2"><i class="fas fa-users text-[var(--color-purple)] mr-2"></i>Allies welcome</h3>
                        <p class="text-gray-200 text-sm leading-relaxed">You don't need to be LGBTQ+ to attend. Straight allies, friends, and families are a big part of what makes Pride powerful. Come and celebrate with us.</p>
                    </div>
                    <div class="border-l-4 border-[var(--color-pink)] pl-5">
                        <h3 class="text-white font-bold text-sm uppercase mb-2"><i class="fas fa-child text-[var(--color-pink)] mr-2"></i>Bringing kids?</h3>
                        <p class="text-gray-200 text-sm leading-relaxed">The parade is family-friendly and brilliant for kids — expect colour, music, and lots of waving. Under 12s go free to the festival (book online). Under 18s must be with an adult.</p>
                    </div>
                </div>
            </div>
