---
import PublicLayout from '../components/PublicLayout.astro';

const collectionPage = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'LGBTQ+ Venues and Gay Bars in Birmingham and the West Midlands',
  description:
    'A comprehensive directory of LGBTQ+ friendly bars, clubs, saunas, and social spaces in Birmingham and the West Midlands, UK.',
  url: 'https://www.brumoutloud.co.uk/all-venues',
  mainEntity: {
    '@type': 'ItemList',
    name: 'LGBTQ+ Venues Birmingham',
    description: 'A curated list of LGBTQ+ friendly venues in Birmingham',
  },
  breadcrumb: {
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://www.brumoutloud.co.uk/' },
      { '@type': 'ListItem', position: 2, name: 'Venues', item: 'https://www.brumoutloud.co.uk/all-venues' },
    ],
  },
  isPartOf: {
    '@type': 'WebSite',
    name: 'Brum Outloud',
    url: 'https://www.brumoutloud.co.uk',
  },
};

const faqPage = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'How many gay bars are in Birmingham?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: "Birmingham has 9 LGBTQ+ bars and venues, mostly in the Gay Village on Hurst Street. Key venues include The Fox, The Nightingale Club, Missing Bar, Eden Bar, The Village Inn, Equator Bar, Glamorous, The Fountain Inn, and The Hub.",
      },
    },
    {
      '@type': 'Question',
      name: 'Where is the Gay Village in Birmingham?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: "Birmingham's Gay Village is in the Southside area, centred on Hurst Street. It's a 5-minute walk from Birmingham New Street station — head south past the Bullring and you'll reach it within minutes.",
      },
    },
    {
      '@type': 'Question',
      name: "Are Birmingham's gay bars welcoming to everyone?",
      acceptedAnswer: {
        '@type': 'Answer',
        text: "Yes. Birmingham's LGBTQ+ venues welcome everyone regardless of gender identity or sexual orientation. Most venues are mixed, inclusive spaces. Some host specific nights (e.g. women-only or bear nights) but all are welcoming to allies and first-time visitors.",
      },
    },
  ],
};

const venues = [
  {
    slug: 'glamorous',
    name: 'Glamorous',
    address: '27-35 Hurst St, Birmingham, B5 4BD',
    image: 'https://res.cloudinary.com/dbxhpjoiz/image/upload/v1750526040/brumoutloud_venues/cghnw3anncyelp8q6bqi.jpg',
    description: 'LGBTQIA+ Nightclub; Booming and energetic venue catering to any age; Open until the early hours to keep the party going.',
    eager: true,
  },
  {
    slug: 'the-fountain-inn',
    name: 'The Fountain inn',
    address: '102 Wrentham St, Birmingham B5 6QL',
    image: 'https://res.cloudinary.com/dbxhpjoiz/image/upload/v1750525630/brumoutloud_venues/skll02caqypuu6mcwevi.jpg',
    description: 'Bar and rooms establishment; Traditional gay bar; Formerly men-only, now welcomes everyone.',
  },
  {
    slug: 'the-village-inn',
    name: 'The Village Inn',
    address: '18 Kent St, Birmingham B5 6RD',
    image: 'https://res.cloudinary.com/dbxhpjoiz/image/upload/v1750523779/brumoutloud_venues/eef3pldclnhaahgsvcdb.jpg',
    description: 'Cabaret bar; Beating heart of the Gay Village; Always buzzing; Guarantees a warm welcome and a memorable night.',
  },
  {
    slug: 'the-fox',
    name: 'The Fox',
    address: '17 Lower Essex St, Birmingham, B5 6SN',
    image: 'https://res.cloudinary.com/dbxhpjoiz/image/upload/v1750524201/brumoutloud_venues/gh2pkfvu5vgg9cxcczjc.jpg',
    description: "One of Birmingham's oldest and most loved LGBTQ+ pubs; Traditional Victorian pub; Warm and welcoming atmosphere; Particular favourite with the lesbian community, but inclusive to all.",
  },
  {
    slug: 'the-nightingale-club',
    name: 'The Nightingale Club',
    address: '18 Kent Street, Birmingham, B5 6RD, UK',
    image: 'https://res.cloudinary.com/dbxhpjoiz/image/upload/v1750521804/brumoutloud_venues/zpxr6pjmy6nd8vj25aup.jpg',
    description: "Birmingham's oldest and largest LGBT venue; Heart of the local LGBTQIA+ nightlife and clubbing scene; Huge venue with capacity for 2000.",
  },
  {
    slug: 'eden-bar',
    name: 'Eden Bar',
    address: '138 Gooch St, Birmingham, B5 7HF',
    image: 'https://res.cloudinary.com/dbxhpjoiz/image/upload/v1750532560/brumoutloud_venues/tl9qhbq5u7s0p7tiopub.webp',
    description: 'Brings the best in live cabaret from across the U.K.; All-inclusive.',
  },
  {
    slug: 'missing-bar',
    name: 'Missing Bar',
    address: '48 Bromsgrove Street, Birmingham, West Midlands, B5 6NU',
    image: 'https://res.cloudinary.com/dbxhpjoiz/image/upload/v1750522112/brumoutloud_venues/hklgqqh62nrj9853vkyi.jpg',
    description: "Birmingham's Party Bar; Lively and welcoming venue; Cornerstone of LGBTQ+ nightlife; Award-winning for friendly atmosphere.",
  },
  {
    slug: 'equator-bar',
    name: 'Equator Bar',
    address: '133 Hurst Street, Birmingham, B5 6SE',
    image: 'https://res.cloudinary.com/dbxhpjoiz/image/upload/v1750524014/brumoutloud_venues/v6ykabboxlkeb1ivshjb.webp',
    description: 'A relaxed and sophisticated LGBTQ+ bar; Perfect for pre-club drinks and cocktails.',
  },
  {
    slug: 'the-hub',
    name: 'The Hub',
    address: 'Within Eden, 138 Gooch St, Birmingham',
    image: 'https://res.cloudinary.com/dbxhpjoiz/image/upload/v1755119210/brumoutloud_venues/z7gqqdtd6kknrxwvw6nr.jpg',
    description: 'Event space with chillout area and roof garden within Eden Bar. Hosts promo events and available to hire.',
  },
];
---
<PublicLayout
  title="Gay Bars Birmingham | Every LGBTQ+ Venue in the Gay Village | Brum Outloud"
  description="Complete guide to every gay bar and LGBTQ+ venue in Birmingham's Gay Village. Reviews, opening hours, events and photos for all venues on the scene."
  canonical="https://www.brumoutloud.co.uk/all-venues"
  watermark="VENUES"
  jsonLd={[collectionPage, faqPage]}
>
  <Fragment slot="head">
    <link rel="preload" as="image" href={venues[0].image} fetchpriority="high">
    <style>
      .btn-primary { background-color: var(--color-pink); color: #000 !important; border: 2px solid var(--color-light); font-weight: 900; text-transform: uppercase; border-radius: 0; transition: all .3s; }
      .btn-primary:hover { background-color: #fff; color: #000 !important; }
      .btn-secondary { background-color: var(--color-purple); color: #fff; border: 2px solid var(--color-light); font-weight: 900; text-transform: uppercase; border-radius: 0; transition: all .3s; }
      .btn-secondary:hover { background-color: var(--color-toxic); color: #000; }
      .venue-card h3, .venue-card p { text-shadow: none; }
      .venue-card h3 { color: var(--color-light); }
      .category-tag { display: inline-block; background-color: var(--color-light); color: #000; border: 2px solid #000; font-weight: bold; text-transform: uppercase; font-size: .75rem; padding: .25rem .75rem; border-radius: 0; flex-shrink: 0; box-shadow: 2px 2px 0 var(--color-toxic); }
      .item-card-image-container { width: 100%; padding-bottom: 75%; position: relative; overflow: hidden; border-radius: 0; background-color: #1a1a1a; border-bottom: 4px solid var(--color-light); }
      .item-card-image { position: absolute; top: 0; left: 0; width: 100%; height: 100%; object-fit: cover; border-radius: 0; filter: contrast(1.1) grayscale(.2); }
      .venue-card:hover .item-card-image { filter: contrast(1.2) grayscale(0); }
    </style>
  </Fragment>

  <main class="container mx-auto px-4 py-12 relative z-10">
    <div class="text-center mb-16 relative">
      <div class="sticker bg-[var(--color-purple)] text-white text-sm mb-4 inline-block transform -rotate-2 uppercase tracking-widest">DIRECTORY</div>
      <h1 class="text-[clamp(4rem,10vw,8.5rem)] font-black text-white uppercase font-display misprint leading-[0.85] mb-6 shadow-glow">
        GAY VILLAGE <br><span class="text-[var(--color-toxic)]">BIRMINGHAM</span>
      </h1>
      <p class="text-xl md:text-2xl font-bold text-white opacity-90 max-w-2xl mx-auto italic mb-8">Discover the iconic bars, clubs, saunas, and LGBTQ+ spaces defined by the scene.</p>
    </div>

    <div id="venue-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 items-start">
      {venues.map((venue) => (
        <a href={`/venue/${venue.slug}`} class="brutalist-card !p-0 group overflow-hidden transition-all duration-300 hover:shadow-glow venue-card">
          <div class="item-card-image-container relative overflow-hidden bg-black">
            <img
              src={venue.image}
              alt={venue.name}
              class="item-card-image w-full h-full object-cover"
              loading={venue.eager ? 'eager' : 'lazy'}
              fetchpriority={venue.eager ? 'high' : undefined}
              decoding={venue.eager ? 'sync' : 'async'}
            />
          </div>
          <div class="p-6">
            <h3 class="text-2xl font-bold mb-3">{venue.name}</h3>
            <p class="text-[var(--color-toxic)] font-bold text-sm mb-3 flex items-center">
              <i class="fas fa-map-marker-alt mr-2"></i>{venue.address}
            </p>
            <p class="text-gray-300 text-sm mb-6 line-clamp-2">{venue.description}</p>
            <div class="flex flex-wrap gap-2 mb-6">
              <span class="category-tag">LGBTQ+</span><span class="category-tag">Venue</span>
            </div>
            <div class="flex justify-end mt-2 relative z-20">
              <span class="text-[var(--color-toxic)] bg-[rgba(204,255,0,0.1)] w-10 h-10 rounded-full flex items-center justify-center group-hover:bg-[var(--color-toxic)] group-hover:text-black transition-colors duration-300">
                <i class="fas fa-arrow-right"></i>
              </span>
            </div>
          </div>
        </a>
      ))}
    </div>

    <div class="aeo-glass-card p-8 mt-20 max-w-5xl mx-auto relative overflow-hidden group">
      <div class="absolute top-0 left-0 w-full h-1 progress-pride-bg"></div>
      <div class="flex flex-col sm:flex-row items-start gap-8 relative z-10">
        <div class="hidden sm:flex text-[var(--color-toxic)] text-4xl mt-1 shadow-glow">
          <i class="fas fa-search-location"></i>
        </div>
        <div>
          <h2 class="text-white text-2xl font-black mb-4 font-display uppercase tracking-widest leading-none shadow-glow">Birmingham has 9 LGBTQ+ bars and venues, most located in the Gay Village on Hurst Street, Southside.</h2>
          <p class="text-gray-200 text-lg leading-relaxed opacity-90">The village is a 5-minute walk from New Street station. Key venues include <a href="/venue/the-fox" class="text-[var(--color-pink)] font-bold hover:text-white transition-colors underline decoration-2 underline-offset-4">The Fox</a>, <a href="/venue/the-nightingale-club" class="text-[var(--color-pink)] font-bold hover:text-white transition-colors underline decoration-2 underline-offset-4">The Nightingale Club</a>, and <a href="/venue/the-village-inn" class="text-[var(--color-pink)] font-bold hover:text-white transition-colors underline decoration-2 underline-offset-4">The Village Inn</a>.</p>
        </div>
      </div>
    </div>
  </main>
</PublicLayout>
