---
import AdminLayout from '../components/AdminLayout.astro';
---
<AdminLayout title="Poster Parser" activeNav="admin-poster-tool.html" breadcrumbSection="System" breadcrumbPage="Poster Parser">
  <Fragment slot="head">
    <style>
        .card-bg {
            background: rgba(17, 24, 39, 0.7);
            backdrop-filter: blur(20px);
            border: 1px solid rgba(75, 85, 99, 0.3);
        }

        .btn-primary {
            background: linear-gradient(135deg, #E83A99 0%, #8B5CF6 100%);
            border: 1px solid rgba(232, 58, 153, 0.3);
        }

        .btn-primary:hover {
            background: linear-gradient(135deg, #D61F69 0%, #7C3AED 100%);
            transform: translateY(-1px);
        }

        .btn-secondary {
            background: rgba(75, 85, 99, 0.3);
            border: 1px solid rgba(75, 85, 99, 0.5);
        }

        .btn-secondary:hover {
            background: rgba(75, 85, 99, 0.5);
        }

        .btn-success {
            background: linear-gradient(135deg, #10B981 0%, #059669 100%);
            border: 1px solid rgba(16, 185, 129, 0.3);
        }

        .btn-success:hover {
            background: linear-gradient(135deg, #059669 0%, #047857 100%);
            transform: translateY(-1px);
        }

        .heading-gradient {
            background: linear-gradient(135deg, #FFFFFF 0%, #E83A99 50%, #8B5CF6 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .accent-color {
            color: #E83A99;
        }

        .accent-color-secondary {
            color: #8B5CF6;
        }

        .form-input {
            background: rgba(31, 41, 55, 0.8);
            border: 1px solid rgba(75, 85, 99, 0.5);
            backdrop-filter: blur(10px);
        }

        .form-input:focus {
            border-color: #E83A99;
            box-shadow: 0 0 0 3px rgba(232, 58, 153, 0.1);
        }

        .upload-area {
            background: rgba(31, 41, 55, 0.3);
            border: 2px dashed rgba(75, 85, 99, 0.5);
            transition: all 0.3s ease;
        }

        .upload-area:hover,
        .upload-area.dragover {
            border-color: #E83A99;
            background: rgba(232, 58, 153, 0.1);
        }

        .result-card {
            background: rgba(17, 24, 39, 0.5);
            backdrop-filter: blur(10px);
            border: 1px solid rgba(75, 85, 99, 0.2);
            transition: all 0.3s ease;
        }

        .result-card:hover {
            transform: translateY(-2px);
            border-color: rgba(232, 58, 153, 0.3);
        }
    </style>
    <script is:inline src="/js/main.js"></script>
  </Fragment>

<div class="max-w-[1600px] mx-auto px-4 md:px-6 py-8">
                <!-- Google Tag Manager (noscript) -->
                <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-MMTDFZGH" height="0" width="0"
                        style="display:none;visibility:hidden"></iframe></noscript>
                <!-- End Google Tag Manager (noscript) -->

                <!-- Google Tag Manager -->
                <script>(function (w, d, s, l, i) {
                        w[l] = w[l] || []; w[l].push({
                            'gtm.start':
                                new Date().getTime(), event: 'gtm.js'
                        }); var f = d.getElementsByTagName(s)[0],
                            j = d.createElement(s), dl = l != 'dataLayer' ? '&l=' + l : ''; j.async = true; j.src =
                                'https://www.googletagmanager.com/gtm.js?id=' + i + dl; f.parentNode.insertBefore(j, f);
                    })(window, document, 'script', 'dataLayer', 'GTM-MMTDFZGH');</script>
                <!-- End Google Tag Manager -->
                

        <section class="text-center mb-8">
            <div class="text-center mb-16">
                <h1 class="font-anton text-7xl md:text-8xl leading-none tracking-wider heading-gradient">POSTER <span
                        class="accent-color">PARSER</span></h1>
                <p class="mt-4 text-xl text-gray-300 max-w-2xl mx-auto">Upload an event poster and let the AI extract
                    the details. Review and approve the events to add them to the site.</p>
            </div>

            <div class="card-bg p-8 md:p-12 rounded-2xl">
                <form id="poster-form" class="space-y-6">
                    <div>
                        <label for="poster-file" class="block text-sm font-semibold mb-2 accent-color-secondary">
                            <i class="fas fa-image mr-1"></i>Upload Poster Image
                        </label>
                        <input type="file" id="poster-file" name="poster"
                            class="form-input w-full text-sm text-gray-400 file:mr-4 file:py-3 file:px-4 file:rounded-lg file:border-0 file:bg-gray-700 file:text-white hover:file:bg-gray-600"
                            accept="image/png, image/jpeg, image/gif" required>
                    </div>
                    <div id="image-preview" class="hidden">
                        <p class="text-sm font-semibold mb-2 accent-color-secondary">Image Preview</p>
                        <img id="preview-img" class="rounded-lg max-h-64 mx-auto" alt="Image preview">
                    </div>
                    <div class="pt-4">
                        <button type="submit"
                            class="btn-primary text-white font-bold py-3 px-8 rounded-lg transition-all w-full flex items-center justify-center">
                            <span id="submit-text">
                                <i class="fas fa-magic mr-2"></i>Parse Poster
                            </span>
                            <span id="submit-loader"
                                class="animate-spin rounded-full h-5 w-5 border-b-2 border-white ml-3 hidden"></span>
                        </button>
                    </div>
                </form>

                <div id="results-container" class="mt-12 space-y-6">
                    <!-- Parsed event forms will be injected here -->
                </div>
                <div id="status-message" class="mt-4 text-center"></div>
            </div>
        </section>
        </section>
            </div>


<script is:inline>
        const form = document.getElementById('poster-form');
        const fileInput = document.getElementById('poster-file');
        const imagePreviewContainer = document.getElementById('image-preview');
        const previewImg = document.getElementById('preview-img');
        const submitBtn = form.querySelector('button[type=submit]');
        const submitText = document.getElementById('submit-text');
        const submitLoader = document.getElementById('submit-loader');
        const resultsContainer = document.getElementById('results-container');
        const statusMessage = document.getElementById('status-message');

        fileInput.addEventListener('change', () => {
            const file = fileInput.files[0];
            if (file) {
                const reader = new FileReader();
                reader.onload = (e) => {
                    previewImg.src = e.target.result;
                    imagePreviewContainer.classList.remove('hidden');
                };
                reader.readAsDataURL(file);
            }
        });

        function renderEventForm(eventData, index) {
            const form = document.createElement('form');
            form.className = "event-review-form card-bg p-6 space-y-4";
            form.dataset.index = index;

            form.innerHTML = `<h3 class="font-anton text-2xl text-white">Review Event ${index + 1}</h3>`;

            const createField = (labelText, name, type, value, placeholder = '', rows = 0) => {
                const div = document.createElement('div');
                div.innerHTML = `<label class="block text-sm font-semibold mb-1 accent-color-secondary">${labelText}</label>`;
                let inputElement;
                if (type === 'textarea') {
                    inputElement = document.createElement('textarea');
                    inputElement.rows = rows;
                    inputElement.textContent = value || '';
                } else {
                    inputElement = document.createElement('input');
                    inputElement.type = type;
                    inputElement.value = value || '';
                }
                inputElement.name = name;
                inputElement.className = 'w-full p-2 bg-gray-900/50 rounded-md';
                if (placeholder) inputElement.placeholder = placeholder;
                div.appendChild(inputElement);
                return div;
            };

            const gridDiv1 = document.createElement('div');
            gridDiv1.className = 'grid md:grid-cols-2 gap-4';
            gridDiv1.appendChild(createField('Name', 'name', 'text', eventData.name));
            gridDiv1.appendChild(createField('Venue', 'venue', 'text', eventData.venue));
            form.appendChild(gridDiv1);

            const gridDiv2 = document.createElement('div');
            gridDiv2.className = 'grid md:grid-cols-2 gap-4';
            gridDiv2.appendChild(createField('Date', 'date', 'date', eventData.date));
            gridDiv2.appendChild(createField('Time (24hr)', 'time', 'time', eventData.time));
            form.appendChild(gridDiv2);

            form.appendChild(createField('Description', 'description', 'textarea', eventData.description, '', 3));

            const gridDiv3 = document.createElement('div');
            gridDiv3.className = 'grid md:grid-cols-2 gap-4';
            gridDiv3.appendChild(createField('Ticket Link', 'ticketLink', 'url', eventData.ticketLink));
            gridDiv3.appendChild(createField('Parent Event Name', 'parentEventName', 'text', eventData.parentEventName));
            form.appendChild(gridDiv3);

            form.appendChild(createField('Recurring Info', 'recurringInfo', 'text', '', 'e.g., Every second Friday'));

            const categoriesString = Array.isArray(eventData.categories) ? eventData.categories.join(', ') : '';
            form.appendChild(createField('Categories (comma-separated)', 'categories', 'text', categoriesString));

            form.appendChild(createField('Contact Email', 'contactEmail', 'email', eventData.contactEmail));

            const promoImageDiv = document.createElement('div');
            promoImageDiv.innerHTML = `
                <label class="block text-sm font-semibold mb-1 accent-color-secondary">Promo Image (Optional Override)</label>
                <input type="file" name="promoImage" class="w-full text-sm text-gray-400 file:mr-4 file:py-2 file:px-4 file:rounded-lg file:border-0 file:bg-gray-700 file:text-white hover:file:bg-gray-600" accept="image/png, image/jpeg, image/gif">
            `;
            form.appendChild(promoImageDiv);

            const buttonDiv = document.createElement('div');
            buttonDiv.className = 'flex justify-end gap-4 pt-2';
            buttonDiv.innerHTML = `
                <button type="button" class="reject-btn bg-red-600/20 text-red-300 font-bold py-2 px-4 rounded-lg">Reject</button>
                <button type="submit" class="approve-btn bg-green-600/20 text-green-300 font-bold py-2 px-4 rounded-lg">Approve & Add</button>
            `;
            form.appendChild(buttonDiv);

            resultsContainer.appendChild(form);
        }

        form.addEventListener('submit', async (e) => {
            e.preventDefault();
            const formData = new FormData(form);
            submitBtn.disabled = true;
            submitText.textContent = 'Processing...';
            submitLoader.classList.remove('hidden');
            resultsContainer.innerHTML = '';
            statusMessage.textContent = 'Uploading image and contacting AI. This may take a moment...';

            try {
                const response = await fetch('/.netlify/functions/process-poster', {
                    method: 'POST',
                    body: formData,
                });

                const result = await response.json();
                console.log("Response from Netlify function:", result);
                if (!response.ok) {
                    console.error("Server response not OK:", result);
                    throw new Error(result.message || 'An unknown server error occurred.');
                }

                statusMessage.textContent = `AI found ${result.length} event(s). Please review and approve.`;
                if (result.length === 0) { statusMessage.textContent = "AI couldn't find any clear event details in this spreadsheet."; }

                console.log("Calling renderEventForm for each result...");
                result.events.forEach(renderEventForm);
                console.log("renderEventForm calls completed.");

            } catch (error) {
                statusMessage.textContent = `Error: ${error.toString()}`;
            } finally {
                submitBtn.disabled = false;
                submitText.textContent = 'Parse Poster';
                submitLoader.classList.add('hidden');
            }
        });

        resultsContainer.addEventListener('click', async (e) => {
            console.log("Click event detected on resultsContainer.");
            const target = e.target;
            console.log("Event target:", target);
            const reviewForm = target.closest('.event-review-form');
            console.log("Closest review form:", reviewForm);
            if (!reviewForm) {
                console.log("No review form found, returning.");
                return;
            }

            if (target.classList.contains('reject-btn')) {
                console.log("Reject button clicked.");
                reviewForm.style.opacity = '0.5';
                reviewForm.innerHTML = '<p class="text-center text-red-400 font-bold">Rejected</p>';
            }

            if (target.classList.contains('approve-btn')) {
                console.log("Approve button clicked.");
                e.preventDefault();
                target.disabled = true;
                target.textContent = 'Adding...';

                const formData = new FormData(reviewForm);
                console.log("FormData entries:", Array.from(formData.entries()));
                try {
                    // Send to the unified Firestore admin creation endpoint
                    const response = await fetch('/.netlify/functions/admin-create-event', {
                        method: 'POST',
                        body: formData
                    });
                    const result = await response.json();
                    if (!response.ok) throw new Error(result.message);

                    reviewForm.style.opacity = '0.5';
                    const eventName = new FormData(reviewForm).get('name');
                    reviewForm.innerHTML = `<p class="text-center text-green-400 font-bold">Approved & Added: ${eventName}</p>`;

                } catch (error) {
                    target.disabled = false;
                    target.textContent = 'Approve & Add';
                    alert(`Error adding event: ${error.toString()}`);
                }
            }
        });
        
        // Mobile menu toggle
        document.querySelector('button.lg\\:hidden')?.addEventListener('click', function() {
            document.querySelector('aside').classList.toggle('hidden');
        });

    </script>
</AdminLayout>
