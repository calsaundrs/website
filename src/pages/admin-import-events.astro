---
import AdminLayout from '../components/AdminLayout.astro';
---
<AdminLayout title="Import Events" activeNav="admin-import-events.html" breadcrumbSection="Import" breadcrumbPage="Import Manager">
  <Fragment slot="head">
    <style>
        .card-bg {
            background: rgba(17, 24, 39, 0.7);
            backdrop-filter: blur(20px);
            border: 1px solid rgba(75, 85, 99, 0.3);
        }

        .heading-gradient {
            background: linear-gradient(135deg, #FFFFFF 0%, #E83A99 50%, #8B5CF6 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .accent-color {
            color: #E83A99;
        }
    </style>
    <script is:inline src="/js/main.js"></script>
  </Fragment>

<div class="max-w-7xl mx-auto px-4 sm:px-8 py-8 md:py-12">
        <section class="max-w-4xl mx-auto">
            <div class="text-center mb-12">
                <h1 class="font-anton text-5xl md:text-7xl leading-none tracking-wider heading-gradient mb-4">
                    IMPORT <span class="accent-color">EVENTS</span>
                </h1>
                <p class="text-xl text-gray-300">Paste JSON array of events below to auto-import via API</p>
            </div>

            <div class="card-bg p-8 rounded-2xl">
                <div class="mb-4">
                    <label for="json-input" class="block text-sm font-medium text-gray-400 mb-2">Events JSON
                        Array</label>
                    <textarea id="json-input" rows="15"
                        class="w-full bg-gray-800 border border-gray-700 rounded-lg p-4 text-green-400 font-mono text-sm focus:ring-2 focus:ring-purple-500 focus:border-transparent transition-all outline-none"
                        placeholder='[\n  {\n    "name": "Sample Event",\n    "date": "2026-04-10",\n    "venueName": "Nightingale Club",\n    "imageUrl": "https://..."\n  }\n]'></textarea>
                    <p class="text-xs text-gray-500 mt-2"><i class="fas fa-info-circle mr-1"></i> Data parses
                        automatically. Changes are debounced by 1500ms.</p>
                </div>

                <!-- Status Container -->
                <div id="status-container" class="hidden mt-6 p-4 rounded-lg bg-gray-800 border border-gray-700">
                    <div class="flex items-center gap-3 mb-2">
                        <div id="status-icon" class="text-xl"></div>
                        <h3 id="status-title" class="font-bold text-lg text-white">Status</h3>
                    </div>
                    <div id="status-message" class="text-sm text-gray-300 whitespace-pre-wrap"></div>
                    <div id="results-list" class="mt-4 space-y-2 hidden max-h-64 overflow-y-auto pr-2"></div>
                </div>
            </div>
        </section>
        </section>
            </div>


<script is:inline>
        let debounceTimer;
        const jsonInput = document.getElementById('json-input');
        const statusContainer = document.getElementById('status-container');
        const statusIcon = document.getElementById('status-icon');
        const statusTitle = document.getElementById('status-title');
        const statusMessage = document.getElementById('status-message');
        const resultsList = document.getElementById('results-list');

        function updateStatus(type, title, message) {
            statusContainer.classList.remove('hidden');
            resultsList.classList.add('hidden');
            resultsList.innerHTML = '';

            switch (type) {
                case 'parsing':
                    statusContainer.className = 'mt-6 p-4 rounded-lg bg-blue-900/40 border border-blue-700/50';
                    statusIcon.innerHTML = '<i class="fas fa-circle-notch fa-spin text-blue-400"></i>';
                    statusTitle.className = 'font-bold text-lg text-blue-300';
                    break;
                case 'uploading':
                    statusContainer.className = 'mt-6 p-4 rounded-lg bg-purple-900/40 border border-purple-700/50';
                    statusIcon.innerHTML = '<i class="fas fa-cloud-upload-alt animate-bounce text-purple-400"></i>';
                    statusTitle.className = 'font-bold text-lg text-purple-300';
                    break;
                case 'success':
                    statusContainer.className = 'mt-6 p-4 rounded-lg bg-green-900/40 border border-green-700/50';
                    statusIcon.innerHTML = '<i class="fas fa-check-circle text-green-400"></i>';
                    statusTitle.className = 'font-bold text-lg text-green-300';
                    resultsList.classList.remove('hidden');
                    break;
                case 'error':
                    statusContainer.className = 'mt-6 p-4 rounded-lg bg-red-900/40 border border-red-700/50';
                    statusIcon.innerHTML = '<i class="fas fa-exclamation-triangle text-red-400"></i>';
                    statusTitle.className = 'font-bold text-lg text-red-300';
                    break;
            }

            statusTitle.innerText = title;
            statusMessage.innerText = message;
        }

        async function processJson() {
            const rawValue = jsonInput.value.trim();
            if (!rawValue) {
                statusContainer.classList.add('hidden');
                return;
            }

            let eventsArray = [];
            try {
                eventsArray = JSON.parse(rawValue);
                if (!Array.isArray(eventsArray)) {
                    throw new Error("JSON must be an array of event objects.");
                }
            } catch (e) {
                updateStatus('error', 'Ready JSON Error', 'Invalid JSON payload. Please fix syntax: \n' + e.message);
                return;
            }

            if (eventsArray.length === 0) {
                updateStatus('error', 'Empty Array', 'The array contains no events.');
                return;
            }

            updateStatus('uploading', 'Importing Events...', `Found ${eventsArray.length} valid events. Uploading securely...`);

            try {
                const payload = {
                events: eventsArray
            };

            const response = await fetch('/.netlify/functions/import-events-json', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify(payload)
                });

                const data = await response.json();

                if (!response.ok) {
                    throw new Error(data.error || 'API Error: ' + response.statusText);
                }

                if (data.success) {
                    updateStatus('success', 'Import Complete', `Processed ${data.results.length} events. Website is rebuilding.`);

                    // Render results list
                    data.results.forEach(res => {
                        const item = document.createElement('div');
                        item.className = 'flex items-center justify-between p-2 rounded bg-gray-900/50 border border-gray-700';
                        item.innerHTML = `
                        <div class="flex items-center gap-3">
                            ${res.success ? '<i class="fas fa-check text-green-400"></i>' : '<i class="fas fa-times text-red-400"></i>'}
                            <span class="font-medium truncate max-w-xs" title="${res.name}">${res.name}</span>
                        </div>
                        <span class="text-xs ${res.success ? 'text-gray-400' : 'text-red-400'}">${res.success ? 'Imported' : (res.error || 'Failed')}</span>
                    `;
                        resultsList.appendChild(item);
                    });

                    // Clear input after success
                    jsonInput.value = '';
                } else {
                    updateStatus('error', 'Import Failed', data.message || 'Unknown error occurred.');
                }

            } catch (e) {
                updateStatus('error', 'Network or Server Error', e.message);
            }
        }

        jsonInput.addEventListener('input', () => {
            clearTimeout(debounceTimer);
            const rawValue = jsonInput.value.trim();
            if (rawValue) {
                updateStatus('parsing', 'Waiting to parse...', 'Pausing typing to trigger JSON import process.');
            } else {
                statusContainer.classList.add('hidden');
            }

            debounceTimer = setTimeout(processJson, 1500);
        });

        // Mobile menu toggle
        document.querySelector('button.lg\\:hidden')?.addEventListener('click', function() {
            document.querySelector('aside').classList.toggle('hidden');
        });
    </script>
</AdminLayout>
