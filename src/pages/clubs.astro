---
import PublicLayout from '../components/PublicLayout.astro';

const collectionPage = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'LGBTQ+ Sports Teams & Social Clubs in Birmingham and the West Midlands',
  description: 'A directory of LGBTQ+ sports teams, social groups, and community clubs in Birmingham and the West Midlands.',
  url: 'https://www.brumoutloud.co.uk/clubs',
  breadcrumb: {
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://www.brumoutloud.co.uk/' },
      { '@type': 'ListItem', position: 2, name: 'Community', item: 'https://www.brumoutloud.co.uk/community' },
      { '@type': 'ListItem', position: 3, name: 'Clubs & Groups', item: 'https://www.brumoutloud.co.uk/clubs' },
    ],
  },
  about: { '@type': 'Thing', name: 'LGBTQ+ Community Groups' },
};

const itemList = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'LGBTQ+ Clubs and Groups in Birmingham',
  description: 'Comprehensive list of LGBTQ+ sports, arts, social and support groups in Birmingham.',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Birmingham Bulls RFC', url: 'https://www.brumoutloud.co.uk/clubs#sports' },
    { '@type': 'ListItem', position: 2, name: 'Birmingham Blaze FC', url: 'https://www.brumoutloud.co.uk/clubs#sports' },
    { '@type': 'ListItem', position: 3, name: 'Birmingham Swifts', url: 'https://www.brumoutloud.co.uk/clubs#sports' },
    { '@type': 'ListItem', position: 4, name: 'Rainbow Voices', url: 'https://www.brumoutloud.co.uk/clubs#arts' },
    { '@type': 'ListItem', position: 5, name: 'Birmingham Gaymers', url: 'https://www.brumoutloud.co.uk/clubs#social' },
    { '@type': 'ListItem', position: 6, name: 'TransBrum', url: 'https://www.brumoutloud.co.uk/clubs#community' },
  ],
};

const faqPage = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    { '@type': 'Question', name: 'Are there LGBTQ+ sports teams in Birmingham?', acceptedAnswer: { '@type': 'Answer', text: 'Yes. Birmingham has several LGBTQ+ sports teams including Birmingham Bulls RFC (rugby), Birmingham Blaze FC (football), Birmingham Swifts (running), MOB Badminton, and LGBTQ+ swimming groups. Most welcome all abilities and are beginner-friendly.' } },
    { '@type': 'Question', name: 'How do I join an LGBTQ+ club in Birmingham?', acceptedAnswer: { '@type': 'Answer', text: "Most LGBTQ+ clubs in Birmingham are drop-in friendly — no membership or sign-up required for your first session. Check the group's social media or website for session times and locations, then just turn up. Groups like Birmingham Gaymers, MOB Badminton, and Birmingham Swifts are great for newcomers." } },
    { '@type': 'Question', name: "Are there LGBTQ+ social groups that aren't sports?", acceptedAnswer: { '@type': 'Answer', text: 'Yes. Birmingham has LGBTQ+ book clubs, gaming groups (Birmingham Gaymers), choirs (Rainbow Voices), creative writing groups, and community support organisations like TransBrum and Birmingham LGBT. There are options for every interest beyond the bar and club scene.' } },
  ],
};
---
<PublicLayout
  title="LGBTQ+ Clubs & Groups in Birmingham | Brum Outloud"
  description="Find LGBTQ+ sports teams, social groups, arts collectives and community clubs across Birmingham and the West Midlands. 25+ listed."
  canonical="https://www.brumoutloud.co.uk/clubs"
  watermark="CLUBS"
  jsonLd={[collectionPage, itemList, faqPage]}
>
  <Fragment slot="head">
    <style>
      .glass-panel { background: var(--color-bg); border-bottom: 2px solid var(--color-pink); }
      .filter-pill { padding: 0.5rem 1.25rem; font-weight: 900; font-size: 0.875rem; text-transform: uppercase; letter-spacing: 0.05em; border: 2px solid var(--color-light); background: #000; color: var(--color-light); cursor: pointer; transition: all 0.2s ease; white-space: nowrap; display: flex; align-items: center; justify-content: center; box-shadow: 2px 2px 0 var(--color-purple); }
      .filter-pill:hover { background: var(--color-purple); border-color: var(--color-toxic); transform: translate(-1px, -1px); box-shadow: 4px 4px 0 var(--color-toxic); }
      .filter-pill.active { background: var(--color-toxic); color: #000; border-color: #000; box-shadow: 4px 4px 0 var(--color-purple); }
      .club-card { border: 4px solid var(--color-light); box-shadow: 8px 8px 0 var(--color-purple); background: #000; transition: transform 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275), box-shadow 0.4s ease; overflow: hidden; position: relative; }
      .club-card:hover { transform: translateY(-8px) scale(1.02); box-shadow: 16px 16px 0 var(--color-pink); border-color: var(--color-white); z-index: 10; }
      .club-card-body { padding: 1.5rem; }
      .club-card-img { width: 100%; height: 180px; object-fit: cover; transition: transform 0.4s ease; display: block; }
      .club-card:hover .club-card-img { transform: scale(1.05); }
      .club-card-logo { width: 56px; height: 56px; object-fit: contain; border: 2px solid var(--color-light); background: #fff; flex-shrink: 0; }
      .section-divider { height: 6px; background: repeating-linear-gradient(45deg, var(--color-toxic), var(--color-toxic) 10px, #000 10px, #000 20px); }
    </style>
  </Fragment>

  <section class="max-w-6xl mx-auto px-6 md:px-12 pt-10 pb-6 relative">
    <div class="sticker bg-[var(--color-pink)] text-white text-sm mb-6 inline-block transform -rotate-2">25+ CLUBS & GROUPS</div>
    <h1 class="text-[clamp(4rem,10vw,8.5rem)] font-black text-white uppercase font-display misprint leading-[0.85] mb-8 shadow-glow">
      Find Your<br><span class="text-[var(--color-toxic)]">People.</span>
    </h1>
    <div class="flex flex-col md:flex-row gap-8 items-center mb-12">
      <p class="text-white text-xl md:text-2xl font-bold max-w-xl opacity-90 italic">Birmingham's queer community goes way beyond the bar scene. Sports teams, social groups, creative clubs and support networks — get involved, bab.</p>
    </div>
    <div class="aeo-glass-card p-8 max-w-4xl mb-12 relative overflow-hidden group">
      <div class="absolute top-0 left-0 w-full h-1 progress-pride-bg"></div>
      <p class="text-white text-lg font-bold mb-3">Birmingham has 25+ LGBTQ+ <a href="/community" class="text-[var(--color-pink)] hover:text-white transition-colors underline decoration-2 underline-offset-4">clubs and groups</a> covering sports, arts, social, and community support — most are drop-in friendly.</p>
      <p class="text-gray-300">From inclusive rugby with <strong class="text-white">Birmingham Bulls RFC</strong> to board games with <strong class="text-white">Birmingham Gaymers</strong>, there's something for everyone beyond the bar scene. Browse by category below.</p>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-12 gap-6 mb-8">
      <div class="md:col-span-8 brutalist-card !p-0 overflow-hidden transition-all duration-500 hover:shadow-glow transform rotate-[-0.5deg]">
        <img src="https://birminghambullsrfc.com/assets/images/about-team.jpg" alt="Birmingham Bulls RFC team photo" class="w-full h-64 md:h-96 object-cover filter contrast-125 saturate-110" loading="eager" onerror="this.style.display='none'">
      </div>
      <div class="md:col-span-4 flex flex-col gap-6">
        <div class="brutalist-card !p-0 overflow-hidden transition-all duration-500 hover:shadow-glow h-1/2 transform rotate-[1deg]">
          <img src="https://rainbowvoices.co.uk/wp-content/uploads/2025/02/Birmingham-Pride-Performance-1024x768.jpg" alt="Rainbow Voices performing at Birmingham Pride" class="w-full h-full object-cover filter contrast-125 saturate-110" loading="eager" onerror="this.parentElement.style.display='none'">
        </div>
        <div class="brutalist-card !p-0 overflow-hidden transition-all duration-500 hover:shadow-glow h-1/2 transform rotate-[-1deg]">
          <img src="https://i0.wp.com/birminghamswifts.co.uk/wp-content/uploads/2025/05/parkrun-takeover-May-2025-scaled.jpg?fit=1440%2C960&ssl=1" alt="Birmingham Swifts parkrun takeover" class="w-full h-full object-cover filter contrast-125 saturate-110" loading="eager" onerror="this.parentElement.style.display='none'">
        </div>
      </div>
    </div>
  </section>

  <section class="max-w-6xl mx-auto px-6 md:px-12 pb-12">
    <p class="text-gray-200 text-xs uppercase tracking-widest mb-4"><i class="fas fa-check-circle text-[var(--color-toxic)] mr-1"></i> Last verified: March 2026 · <a href="/contact" class="text-[var(--color-pink)] hover:text-white">Report outdated info</a></p>
    <div class="flex flex-wrap gap-3 items-center">
      <button class="filter-pill active focus-visible:outline-none focus-visible:ring-4 focus-visible:ring-[var(--color-toxic)] rounded-sm" data-filter="all" aria-pressed="true">All</button>
      <button class="filter-pill focus-visible:outline-none focus-visible:ring-4 focus-visible:ring-[var(--color-toxic)] rounded-sm" data-filter="sports" aria-pressed="false">Sports & Fitness</button>
      <button class="filter-pill focus-visible:outline-none focus-visible:ring-4 focus-visible:ring-[var(--color-toxic)] rounded-sm" data-filter="arts" aria-pressed="false">Arts & Culture</button>
      <button class="filter-pill focus-visible:outline-none focus-visible:ring-4 focus-visible:ring-[var(--color-toxic)] rounded-sm" data-filter="social" aria-pressed="false">Social & Gaming</button>
      <button class="filter-pill focus-visible:outline-none focus-visible:ring-4 focus-visible:ring-[var(--color-toxic)] rounded-sm" data-filter="community" aria-pressed="false">Community & Support</button>
    </div>
  </section>

  <main class="max-w-6xl mx-auto px-6 md:px-12 pb-20">
    <section class="mb-16 brutalist-card !border-[var(--color-toxic)] p-8 md:p-12 transform rotate-[-0.5deg]">
      <div class="flex flex-col md:flex-row gap-10 justify-between items-center relative z-10">
        <div class="md:w-5/12 lg:w-1/3 text-center md:text-left">
          <h2 class="text-4xl lg:text-5xl font-black text-white uppercase font-display misprint leading-[0.8] mb-6 shadow-glow">Don't know<br>where to<br>start?</h2>
          <p class="text-white opacity-80 text-xl font-bold leading-tight">These groups are drop-in friendly. No commitment, just turn up and say hi.</p>
        </div>
        <div class="md:w-7/12 lg:w-2/3 grid grid-cols-1 sm:grid-cols-2 gap-6 w-full">
          <div class="brutalist-card p-6 group h-full hover:bg-white/5 transition-colors">
            <p class="text-white font-black text-2xl uppercase mb-2 group-hover:text-[var(--color-toxic)] transition-colors"><i class="fas fa-dice text-[var(--color-toxic)] mr-2"></i>Birmingham Gaymers</p>
            <p class="text-[var(--color-light)] opacity-70 font-bold uppercase tracking-widest text-xs">Selly Oak · £4 · Monthly</p>
          </div>
          <div class="brutalist-card p-6 group h-full !border-[var(--color-purple)] hover:bg-white/5 transition-colors">
            <p class="text-white font-black text-2xl uppercase mb-2 group-hover:text-[var(--color-toxic)] transition-colors"><i class="fas fa-table-tennis text-[var(--color-toxic)] mr-2"></i>MOB Badminton</p>
            <p class="text-[var(--color-light)] opacity-70 font-bold uppercase tracking-widest text-xs">Aston Uni · £6 · Weekly</p>
          </div>
          <div class="brutalist-card p-6 group h-full !border-[var(--color-pink)] sm:col-span-2 hover:bg-white/5 transition-colors">
            <p class="text-white font-black text-2xl uppercase mb-2 group-hover:text-[var(--color-toxic)] transition-colors"><i class="fas fa-shoe-prints text-[var(--color-toxic)] mr-2"></i>Birmingham Swifts</p>
            <p class="text-[var(--color-light)] opacity-70 font-bold uppercase tracking-widest text-xs">All paces welcome · <span class="text-[var(--color-toxic)]">FREE</span></p>
          </div>
        </div>
      </div>
    </section>

    <section data-category="sports" class="mb-16">
      <div class="flex items-center gap-3 mb-6">
        <h2 class="sticker bg-[var(--color-toxic)] !text-black text-sm"><i class="fas fa-running mr-1"></i> SPORTS & FITNESS</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-6">
        <div class="brutalist-card !p-0 overflow-hidden group hover:shadow-glow transition-all duration-300">
          <img src="https://birminghambullsrfc.com/assets/images/about-team.jpg" alt="Birmingham Bulls RFC team" class="club-card-img" loading="lazy" onerror="this.style.display='none'">
          <div class="club-card-body">
            <div class="flex items-center gap-3 mb-1">
              <img src="https://birminghambullsrfc.com/assets/images/bulls-logo.png" alt="" class="club-card-logo" aria-hidden="true" loading="lazy" onerror="this.style.display='none'">
              <div>
                <h3 class="text-xl font-black text-white uppercase font-display leading-tight">Birmingham Bulls RFC</h3>
                <p class="text-[var(--color-toxic)] font-bold text-sm"><i class="fas fa-football-ball mr-1"></i> Rugby</p>
              </div>
            </div>
            <p class="text-gray-200 text-sm mb-3 mt-2">Gay and inclusive rugby union team. Competed at the Bingham Cup and hosted the Union Cup 2023 — Europe's largest LGBTQ+ rugby tournament. Founded 2011.</p>
            <p class="text-gray-300 text-xs mb-3"><i class="fas fa-map-marker-alt text-[var(--color-pink)] mr-1"></i> Check website for training location & times · All welcome, no experience needed</p>
            <div class="flex flex-wrap gap-3">
              <a href="https://birminghambullsrfc.com" target="_blank" rel="noopener noreferrer" class="text-[var(--color-pink)] font-bold text-sm hover:text-white transition-colors">birminghambullsrfc.com <i class="fas fa-external-link-alt text-xs"></i></a>
              <a href="https://www.instagram.com/birminghambullsrfc/" target="_blank" rel="noopener noreferrer" class="text-gray-300 hover:text-white text-sm transition-colors"><i class="fab fa-instagram"></i> @birminghambullsrfc</a>
            </div>
          </div>
        </div>
        <div class="brutalist-card !p-0 overflow-hidden group hover:shadow-glow transition-all duration-300">
          <img src="https://lgbthistoryuk.org/w/images/e/eb/Birmingham_Blaze.jpg" alt="Birmingham Blaze FC" class="club-card-img" loading="lazy" onerror="this.style.display='none'">
          <div class="club-card-body">
            <h3 class="text-xl font-black text-white uppercase font-display leading-tight mb-1">Birmingham Blaze FC</h3>
            <p class="text-[var(--color-toxic)] font-bold text-sm mb-2"><i class="fas fa-futbol mr-1"></i> Football</p>
            <p class="text-gray-200 text-sm mb-3">All-gender inclusive LGBTQ+ football team. Open to all experience levels. Founded 2005.</p>
            <p class="text-gray-300 text-xs mb-3"><i class="fas fa-clock text-[var(--color-toxic)] mr-1"></i> Weds evenings (training) · Sun mornings (matches)</p>
            <div class="flex flex-wrap gap-3">
              <a href="https://birminghamblazefc.com" target="_blank" rel="noopener noreferrer" class="text-[var(--color-pink)] font-bold text-sm hover:text-white transition-colors">birminghamblazefc.com <i class="fas fa-external-link-alt text-xs"></i></a>
              <a href="https://www.instagram.com/birminghamblazefc/" target="_blank" rel="noopener noreferrer" class="text-gray-300 hover:text-white text-sm transition-colors"><i class="fab fa-instagram"></i> @birminghamblazefc</a>
            </div>
          </div>
        </div>
        <div class="brutalist-card !p-0 overflow-hidden group hover:shadow-glow transition-all duration-300">
          <img src="https://i0.wp.com/birminghamswifts.co.uk/wp-content/uploads/2025/05/parkrun-takeover-May-2025-scaled.jpg?fit=1440%2C960&ssl=1" alt="Birmingham Swifts parkrun" class="club-card-img" loading="lazy" onerror="this.style.display='none'">
          <div class="club-card-body">
            <div class="flex items-center gap-3 mb-1">
              <img src="https://birminghamswifts.co.uk/wp-content/uploads/2025/06/Blue-2025-logo-reduced.jpg" alt="" class="club-card-logo" aria-hidden="true" loading="lazy" onerror="this.style.display='none'">
              <div>
                <h3 class="text-xl font-black text-white uppercase font-display leading-tight">Birmingham Swifts</h3>
                <p class="text-[var(--color-toxic)] font-bold text-sm"><i class="fas fa-shoe-prints mr-1"></i> Running</p>
              </div>
            </div>
            <p class="text-gray-200 text-sm mb-3 mt-2">Free LGBTQ+ running club for all abilities. Couch to 5K programmes, social runs, and post-run socials at The Fox. Also runs a 50+ subgroup.</p>
            <p class="text-gray-300 text-xs mb-3"><i class="fas fa-clock text-[var(--color-toxic)] mr-1"></i> Thurs evenings (social run) · Sat mornings (parkrun) · <strong class="text-white">FREE</strong></p>
            <div class="flex flex-wrap gap-3">
              <a href="https://birminghamswifts.co.uk" target="_blank" rel="noopener noreferrer" class="text-[var(--color-pink)] font-bold text-sm hover:text-white transition-colors">birminghamswifts.co.uk <i class="fas fa-external-link-alt text-xs"></i></a>
              <a href="https://www.instagram.com/birminghamswifts/" target="_blank" rel="noopener noreferrer" class="text-gray-300 hover:text-white text-sm transition-colors"><i class="fab fa-instagram"></i> @birminghamswifts</a>
            </div>
          </div>
        </div>
        <div class="brutalist-card !p-0 overflow-hidden group hover:shadow-glow transition-all duration-300">
          <img src="https://pridesports.org.uk/wp-content/uploads/2019/05/shoals.jpg" alt="Moseley Shoals swimming club" class="club-card-img" loading="lazy" onerror="this.style.display='none'">
          <div class="club-card-body">
            <h3 class="text-xl font-black text-white uppercase font-display leading-tight mb-1">Moseley Shoals</h3>
            <p class="text-[var(--color-toxic)] font-bold text-sm mb-2"><i class="fas fa-swimmer mr-1"></i> Swimming</p>
            <p class="text-gray-200 text-sm mb-3">Social LGBTQ+ swimming club, mixed ability from splash &amp; chat to competition standard. Founded 2000.</p>
            <p class="text-gray-300 text-xs mb-3"><i class="fas fa-clock text-[var(--color-toxic)] mr-1"></i> Mon 8:15pm · Wed 9pm <i class="fas fa-map-marker-alt text-[var(--color-pink)] ml-2 mr-1"></i> Northfield Pool</p>
            <a href="https://moseleyshoals.org.uk" target="_blank" rel="noopener noreferrer" class="text-[var(--color-pink)] font-bold text-sm hover:text-white transition-colors">moseleyshoals.org.uk <i class="fas fa-external-link-alt text-xs"></i></a>
          </div>
        </div>
        <div class="brutalist-card !p-0 overflow-hidden group hover:shadow-glow transition-all duration-300">
          <img src="https://pridesports.org.uk/wp-content/uploads/2019/05/midlandsout.jpg" alt="Midlands Out Badminton" class="club-card-img" loading="lazy" onerror="this.style.display='none'">
          <div class="club-card-body">
            <h3 class="text-xl font-black text-white uppercase font-display leading-tight mb-1">Midlands Out Badminton</h3>
            <p class="text-[var(--color-toxic)] font-bold text-sm mb-2"><i class="fas fa-table-tennis mr-1"></i> Badminton</p>
            <p class="text-gray-200 text-sm mb-3">Friendly LGBTQ+ social badminton. No membership needed — just drop in. Founded 2003.</p>
            <p class="text-gray-300 text-xs mb-3"><i class="fas fa-clock text-[var(--color-toxic)] mr-1"></i> Sat 9:30am–12:30pm <i class="fas fa-map-marker-alt text-[var(--color-pink)] ml-2 mr-1"></i> Aston Uni Sport Centre · <strong class="text-white">£6/session</strong></p>
            <a href="https://midlandsoutbadminton.com" target="_blank" rel="noopener noreferrer" class="text-[var(--color-pink)] font-bold text-sm hover:text-white transition-colors">midlandsoutbadminton.com <i class="fas fa-external-link-alt text-xs"></i></a>
          </div>
        </div>
        <div class="brutalist-card !p-0 overflow-hidden group hover:shadow-glow transition-all duration-300">
          <img src="https://media.sportplan.net/thumbnail/club/4e20/60/300574/logo-1702748610424.png" alt="Birmingham Unicorns CC logo" class="club-card-img" loading="lazy" onerror="this.style.display='none'">
          <div class="club-card-body">
            <h3 class="text-xl font-black text-white uppercase font-display leading-tight mb-1">Birmingham Unicorns CC</h3>
            <p class="text-[var(--color-toxic)] font-bold text-sm mb-2"><i class="fas fa-baseball-ball mr-1"></i> Cricket</p>
            <p class="text-gray-200 text-sm mb-3">LGBTQ+ inclusive cricket — only the second club of its kind in the world. Training at Edgbaston. Open to any age, gender, background or experience. Founded 2020.</p>
            <a href="https://bhamunicorns.co.uk" target="_blank" rel="noopener noreferrer" class="text-[var(--color-pink)] font-bold text-sm hover:text-white transition-colors">bhamunicorns.co.uk <i class="fas fa-external-link-alt text-xs"></i></a>
          </div>
        </div>
        <div class="brutalist-card !p-0 overflow-hidden group hover:shadow-glow transition-all duration-300">
          <img src="https://img1.wsimg.com/isteam/ip/3963e24d-9c9f-43a3-bae6-31720baf463a/Gay%20City%20Bowlers_pink%20logo.png/:/rs=h:200,cg:true,m/qt=q:95" alt="Gay City Bowlers logo" class="club-card-img" loading="lazy" onerror="this.style.display='none'">
          <div class="club-card-body">
            <h3 class="text-xl font-black text-white uppercase font-display leading-tight mb-1">Gay City Bowlers</h3>
            <p class="text-[var(--color-toxic)] font-bold text-sm mb-2"><i class="fas fa-bowling-ball mr-1"></i> Bowling</p>
            <p class="text-gray-200 text-sm mb-3">Monthly LGBTQ+ ten-pin bowling social at Lane 7, The Cube, followed by food and drinks at Eden Bar. £18 per person for 2 games.</p>
            <a href="https://gaycitybowlers.com/birmingham" target="_blank" rel="noopener noreferrer" class="text-[var(--color-pink)] font-bold text-sm hover:text-white transition-colors">gaycitybowlers.com <i class="fas fa-external-link-alt text-xs"></i></a>
          </div>
        </div>
        <div class="brutalist-card !p-0 overflow-hidden group hover:shadow-glow transition-all duration-300">
          <img src="https://images.prismic.io/chaser/aQFaJ7pReVYa3xyX_CorneliaTzana-282.jpg?auto=format,compress" alt="Birmingham Badgers Quadball team" class="club-card-img" loading="lazy" onerror="this.style.display='none'">
          <div class="club-card-body">
            <h3 class="text-xl font-black text-white uppercase font-display leading-tight mb-1">Birmingham Badgers Quadball</h3>
            <p class="text-[var(--color-toxic)] font-bold text-sm mb-2"><i class="fas fa-quidditch mr-1"></i> Quadball</p>
            <p class="text-gray-200 text-sm mb-3">Community Quadball club — the only full-contact mixed-gender sport in the world. Low-pressure, good vibes. Open to all regardless of experience. Founded 2022.</p>
          </div>
        </div>
        <div class="brutalist-card !p-0 overflow-hidden group hover:shadow-glow transition-all duration-300">
          <img src="https://lgbthistoryuk.org/w/images/e/ea/Bootwomen.jpg" alt="Boot Women walking group" class="club-card-img" loading="lazy" onerror="this.style.display='none'">
          <div class="club-card-body">
            <h3 class="text-xl font-black text-white uppercase font-display leading-tight mb-1">Boot Women</h3>
            <p class="text-[var(--color-toxic)] font-bold text-sm mb-2"><i class="fas fa-hiking mr-1"></i> Walking</p>
            <p class="text-gray-200 text-sm mb-3">LGBTQ+ women's walking group. Monthly walks welcoming all abilities.</p>
            <p class="text-gray-300 text-xs mb-3"><i class="fas fa-phone text-[var(--color-toxic)] mr-1"></i> 0121 643 0821 · Ask at the LGBT Centre for current walk schedule</p>
          </div>
