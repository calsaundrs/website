---
import AdminLayout from '../components/AdminLayout.astro';
---
<AdminLayout title="Manage Approved Events" activeNav="admin-edit-events.html" breadcrumbSection="Overview" breadcrumbPage="Manage Events">
  <Fragment slot="head">
    <script is:inline src="/js/admin-edit-events.js?v=5&t=1703123456&r=1234"></script>
    <script is:inline src="/js/main.js"></script>
  </Fragment>

<div class="px-6 lg:px-10 py-10 max-w-[1400px] mx-auto">
                
                <div class="flex flex-col md:flex-row justify-between items-end mb-8 gap-4">
                    <div>
                        <h1 class="text-3xl font-bold text-white mb-2 tracking-tight">Events Overview</h1>
                        <p class="text-gray-400 text-sm">Manage, edit, and organize public and recurring events.</p>
                    </div>
                    <div class="flex gap-3">
                        <button id="bulk-actions-btn" class="bg-[#111] hover:bg-[#1A1A1A] border border-white/10 text-white text-sm font-semibold py-2.5 px-5 rounded-lg transition-all shadow-sm flex items-center">
                            <i class="fas fa-tasks mr-2 text-gray-400"></i> Bulk Actions
                        </button>
                        <button id="add-event-btn" class="bg-white hover:bg-gray-200 text-black border border-transparent text-sm font-bold py-2.5 px-5 rounded-lg transition-all shadow-[0_0_15px_rgba(255,255,255,0.1)] flex items-center">
                            <i class="fas fa-plus mr-2"></i> Add Event
                        </button>
                    </div>
                </div>

                <!-- Sleek Stats Dashboard -->
                <div class="grid grid-cols-1 md:grid-cols-4 gap-4 mb-8">
                    <div class="bg-[#0A0A0A] border border-white/5 rounded-xl p-5 shadow-sm relative overflow-hidden group">
                        <div class="absolute inset-0 bg-gradient-to-br from-white/[0.02] to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
                        <div class="text-xs font-bold uppercase tracking-widest text-gray-500 mb-2">Total Events</div>
                        <div class="text-2xl font-bold text-white tracking-tight" id="total-events-count">-</div>
                    </div>
                    <div class="bg-yellow-500/[0.02] border border-yellow-500/10 rounded-xl p-5 shadow-sm relative overflow-hidden group">
                        <div class="absolute inset-0 bg-gradient-to-br from-yellow-500/[0.05] to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
                        <div class="text-xs font-bold uppercase tracking-widest text-yellow-500/70 mb-2">Pending</div>
                        <div class="text-2xl font-bold text-yellow-500 tracking-tight" id="pending-events-count">-</div>
                    </div>
                    <div class="bg-green-500/[0.02] border border-green-500/10 rounded-xl p-5 shadow-sm relative overflow-hidden group">
                        <div class="absolute inset-0 bg-gradient-to-br from-green-500/[0.05] to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
                        <div class="text-xs font-bold uppercase tracking-widest text-green-500/70 mb-2">Approved</div>
                        <div class="text-2xl font-bold text-green-500 tracking-tight" id="approved-events-count">-</div>
                    </div>
                    <div class="bg-purple-500/[0.02] border border-purple-500/10 rounded-xl p-5 shadow-sm relative overflow-hidden group">
                        <div class="absolute inset-0 bg-gradient-to-br from-purple-500/[0.05] to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
                        <div class="text-xs font-bold uppercase tracking-widest text-purple-500/70 mb-2">Series</div>
                        <div class="text-2xl font-bold text-purple-400 tracking-tight" id="recurring-events-count">-</div>
                    </div>
                </div>

                <!-- Minimalist Search & Filter Bar -->
                <div class="flex flex-col md:flex-row justify-between items-center gap-4 mb-8 bg-[#0A0A0A] border border-white/5 rounded-xl p-2 relative z-10 shadow-sm">
                    <div class="flex space-x-1 p-1 bg-[#050505] rounded-lg border border-white/5">
                        <button data-filter="all" class="filter-btn active px-4 py-2 rounded-md text-xs font-bold transition-all bg-white/10 text-white shadow-sm border border-white/5">Upcoming</button>
                        <button data-filter="recurring" class="filter-btn px-4 py-2 rounded-md text-xs font-semibold text-gray-400 hover:text-white hover:bg-white/5 transition-all">Recurring</button>
                        <button data-filter="past" class="filter-btn px-4 py-2 rounded-md text-xs font-semibold text-gray-400 hover:text-white hover:bg-white/5 transition-all">Past</button>
                        
                        <!-- Ensure the JS filter-btn click handlers still work with these classes. Previously it removed active and added active. -->
                    </div>
                    <div class="relative w-full md:w-80 px-2 lg:px-4">
                        <i class="fas fa-search absolute left-6 lg:left-8 top-1/2 transform -translate-y-1/2 text-gray-500 text-sm"></i>
                        <input type="text" id="search-input" placeholder="Search events..." 
                               class="w-full bg-[#111] border border-white/10 rounded-lg px-4 py-2 pl-10 text-sm text-white placeholder-gray-500 focus:outline-none focus:border-[var(--color-toxic)] focus:ring-1 focus:ring-[var(--color-toxic)] transition-all shadow-sm">
                    </div>
                </div>

            <!-- Error Message -->
            <div id="error-message" class="hidden bg-red-900/50 border border-red-700 text-red-200 px-6 py-4 rounded-lg mb-6 backdrop-blur-sm"></div>

            <!-- Loading State -->
            <div id="loading-state" class="text-center py-16">
                <div class="loader inline-block mb-4"></div>
                <p class="text-gray-400 text-lg">Loading events...</p>
            </div>

            <!-- Regular Events Container -->
            <div id="events-container" class="space-y-6 hidden"></div>

            <!-- Recurring Events Container -->
            <div id="recurring-events-container" class="space-y-6 hidden"></div>

            <!-- Load More -->
            <div id="load-more-container" class="text-center mt-12 hidden">
                <button id="load-more-btn" class="btn-primary text-white font-bold py-3 px-8 rounded-lg transition-all">
                    <i class="fas fa-plus mr-2"></i>Load More Events
                </button>
            </div>
            </div>
            <!-- End of max-w container -->

<!-- Edit Event Modal -->
    <div id="edit-modal" class="fixed inset-0 modal-backdrop flex items-center justify-center p-4 z-50 hidden">
        <div class="modal-content rounded-2xl p-8 w-full max-w-5xl max-h-[90vh] overflow-y-auto">
            <div class="flex justify-between items-center mb-6">
                <h3 id="modal-title" class="font-anton text-3xl text-white">
                    <i class="fas fa-edit mr-3"></i>Edit Event
                </h3>
                <button id="close-modal-btn" class="text-gray-400 hover:text-white text-2xl transition-colors">
                    <i class="fas fa-times"></i>
                </button>
            </div>
            
            <form id="edit-form" class="space-y-8">
                <!-- Event Details Section -->
                <div class="space-y-6">
                    <h4 class="text-xl font-bold accent-color-secondary">
                        <i class="fas fa-calendar-plus mr-2"></i>Event Details
                    </h4>
                    
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div>
                            <label class="block text-sm font-medium text-gray-300 mb-2">
                                <i class="fas fa-tag mr-1"></i>Event Name
                            </label>
                            <input type="text" id="edit-name" name="name" class="form-input w-full px-4 py-3 rounded-lg text-white focus:outline-none" placeholder="Enter event name">
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-gray-300 mb-2">
                                <i class="fas fa-link mr-1"></i>Ticket Link (Optional)
                            </label>
                            <input type="url" id="edit-link" name="link" class="form-input w-full px-4 py-3 rounded-lg text-white focus:outline-none" placeholder="https://">
                        </div>
                    </div>
                    
                    <div>
                        <label class="block text-sm font-medium text-gray-300 mb-2">
                            <i class="fas fa-align-left mr-1"></i>Description
                        </label>
                        <textarea id="edit-description" name="description" rows="4" class="form-input w-full px-4 py-3 rounded-lg text-white focus:outline-none resize-none" placeholder="Describe your event in detail..."></textarea>
                    </div>
                    
                    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                        <div>
                            <label class="block text-sm font-medium text-gray-300 mb-2">
                                <i class="fas fa-calendar mr-1"></i>Date
                            </label>
                            <input type="date" id="edit-date" name="date" class="form-input w-full px-4 py-3 rounded-lg text-white focus:outline-none">
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-gray-300 mb-2">
                                <i class="fas fa-clock mr-1"></i>Time
                            </label>
                            <input type="time" id="edit-time" name="time" class="form-input w-full px-4 py-3 rounded-lg text-white focus:outline-none">
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-gray-300 mb-2">
                                <i class="fas fa-check-circle mr-1"></i>Status
                            </label>
                            <select id="edit-status" name="status" class="form-input w-full px-4 py-3 rounded-lg text-white focus:outline-none">
                                <option value="Pending Review">Pending Review</option>
                                <option value="Approved">Approved</option>
                                <option value="Rejected">Rejected</option>
                            </select>
                        </div>
                    </div>
                    
                    <div>
                        <label class="block text-sm font-medium text-gray-300 mb-2">
                            <i class="fas fa-tags mr-1"></i>Categories
                        </label>
                        <div class="grid grid-cols-2 md:grid-cols-4 gap-3" id="edit-categories">
                            <!-- Categories will be populated dynamically -->
                        </div>
                    </div>
                </div>

                <!-- Venue Details Section -->
                <div class="space-y-6">
                    <h4 class="text-xl font-bold accent-color-secondary">
                        <i class="fas fa-map-marker-alt mr-2"></i>Venue Details
                    </h4>
                    
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div class="md:col-span-2">
                            <label class="block text-sm font-medium text-gray-300 mb-2">
                                <i class="fas fa-map-marker-alt mr-1"></i>Venue
                            </label>
                            <select id="edit-venue-select" name="venueId" class="form-input w-full px-4 py-3 rounded-lg text-white focus:outline-none">
                                <option value="">Select an existing venue...</option>
                                <option value="new">➕ Create New Venue</option>
                            </select>
                            <p class="text-xs text-gray-400 mt-1">Select an existing venue or choose "Create New Venue" below</p>
                        </div>
                    </div>

                    <!-- New Venue Fields (Hidden by default) -->
                    <div id="edit-new-venue-fields" class="hidden space-y-4 transition-all duration-300">
                        <div class="card-bg p-4 rounded-lg border border-blue-600/30">
                            <h5 class="text-blue-300 font-semibold mb-3">
                                <i class="fas fa-plus-circle mr-2"></i>Create New Venue
                            </h5>
                            <p class="text-sm text-blue-200 mb-4">Fill in the details for your new venue below.</p>
                            
                            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                                <div>
                                    <label class="block text-sm font-medium text-gray-300 mb-2">
                                        <i class="fas fa-building mr-1"></i>Venue Name
                                    </label>
                                    <input type="text" id="edit-new-venue-name" name="new-venue-name" class="form-input w-full px-4 py-3 rounded-lg text-white focus:outline-none" placeholder="Enter venue name">
                                </div>
                                <div>
                                    <label class="block text-sm font-medium text-gray-300 mb-2">
                                        <i class="fas fa-map mr-1"></i>Venue Address
                                    </label>
                                    <input type="text" id="edit-new-venue-address" name="new-venue-address" class="form-input w-full px-4 py-3 rounded-lg text-white focus:outline-none" placeholder="e.g., 123 Main Street, Birmingham">
                                </div>
                                <div>
                                    <label class="block text-sm font-medium text-gray-300 mb-2">
                                        <i class="fas fa-mail-bulk mr-1"></i>Postcode
                                    </label>
                                    <input type="text" id="edit-new-venue-postcode" name="new-venue-postcode" class="form-input w-full px-4 py-3 rounded-lg text-white focus:outline-none" placeholder="e.g., B1 1AA">
                                </div>
                                <div>
                                    <label class="block text-sm font-medium text-gray-300 mb-2">
                                        <i class="fas fa-globe mr-1"></i>Venue Website
                                    </label>
                                    <input type="url" id="edit-new-venue-website" name="new-venue-website" class="form-input w-full px-4 py-3 rounded-lg text-white focus:outline-none" placeholder="https://">
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Recurring Event Section -->
                <div class="space-y-6">
                    <h4 class="text-xl font-bold accent-color-secondary">
                        <i class="fas fa-redo mr-2"></i>Recurring Event Settings
                    </h4>
                    
                    <div class="space-y-4">
                        <div class="flex items-center space-x-3">
                            <input type="checkbox" id="edit-is-recurring" name="isRecurring" class="w-5 h-5 text-purple-600 bg-gray-700 border-gray-600 rounded focus:ring-purple-500 focus:ring-2">
                            <label for="edit-is-recurring" class="text-gray-300 font-medium">
                                This is a recurring event
                            </label>
                        </div>
                        
                        <div id="edit-recurring-fields" class="hidden space-y-4">
                            <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                                <div>
                                    <label class="block text-sm font-medium text-gray-300 mb-2">
                                        <i class="fas fa-redo mr-1"></i>Recurring Pattern
                                    </label>
                                    <select id="edit-recurring-pattern" name="recurringPattern" class="form-input w-full px-4 py-3 rounded-lg text-white focus:outline-none">
                                        <option value="">Select a pattern...</option>
                                        <option value="weekly">Weekly</option>
                                        <option value="biweekly">Bi-weekly</option>
                                        <option value="monthly">Monthly</option>
                                        <option value="custom">Custom</option>
                                    </select>
                                </div>
                                <div>
                                    <label class="block text-sm font-medium text-gray-300 mb-2">
                                        <i class="fas fa-calendar-day mr-1"></i>Day of Week
                                    </label>
                                    <select id="edit-recurring-day" name="recurringDay" class="form-input w-full px-4 py-3 rounded-lg text-white focus:outline-none">
                                        <option value="">Select day...</option>
                                        <option value="monday">Monday</option>
                                        <option value="tuesday">Tuesday</option>
                                        <option value="wednesday">Wednesday</option>
                                        <option value="thursday">Thursday</option>
                                        <option value="friday">Friday</option>
                                        <option value="saturday">Saturday</option>
                                        <option value="sunday">Sunday</option>
                                    </select>
                                </div>
                                <div>
                                    <label class="block text-sm font-medium text-gray-300 mb-2">
                                        <i class="fas fa-hashtag mr-1"></i>Instance Number
                                    </label>
                                    <input type="number" id="edit-recurring-instance" name="recurringInstance" min="1" class="form-input w-full px-4 py-3 rounded-lg text-white focus:outline-none" placeholder="e.g., 1, 2, 3...">
                                </div>
                            </div>
                            
                            <div id="edit-custom-pattern-field" class="hidden">
                                <label class="block text-sm font-medium text-gray-300 mb-2">
                                    <i class="fas fa-edit mr-1"></i>Custom Pattern Description
                                </label>
                                <textarea id="edit-recurring-info" name="recurringInfo" rows="3" class="form-input w-full px-4 py-3 rounded-lg text-white focus:outline-none resize-none" placeholder="e.g., Every other Tuesday, First Friday of the month, etc."></textarea>
                            </div>
                            
                            <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                                <div>
                                    <label class="block text-sm font-medium text-gray-300 mb-2">
                                        <i class="fas fa-calendar mr-1"></i>Series Start Date
                                    </label>
                                    <input type="date" id="edit-recurring-start-date" name="recurringStartDate" class="form-input w-full px-4 py-3 rounded-lg text-white focus:outline-none">
                                </div>
                                <div>
                                    <label class="block text-sm font-medium text-gray-300 mb-2">
                                        <i class="fas fa-calendar mr-1"></i>Series End Date (Optional)
                                    </label>
                                    <input type="date" id="edit-recurring-end-date" name="recurringEndDate" class="form-input w-full px-4 py-3 rounded-lg text-white focus:outline-none">
                                </div>
                                <div>
                                    <label class="block text-sm font-medium text-gray-300 mb-2">
                                        <i class="fas fa-hashtag mr-1"></i>Total Instances
                                    </label>
                                    <input type="number" id="edit-total-instances" name="totalInstances" min="1" class="form-input w-full px-4 py-3 rounded-lg text-white focus:outline-none" placeholder="e.g., 12">
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Image Upload Section -->
                <div class="space-y-6">
                    <h4 class="text-xl font-bold accent-color-secondary">
                        <i class="fas fa-image mr-2"></i>Event Image
                    </h4>
                    
                    <div class="space-y-4">
                        <div class="flex items-center space-x-4">
                            <div class="w-24 h-24 bg-gray-700 rounded-lg flex items-center justify-center overflow-hidden">
                                <img id="edit-current-image" src="" alt="Current image" class="w-full h-full object-cover" onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';">
                                <i class="fas fa-image text-2xl text-gray-500" style="display: flex;"></i>
                            </div>
                            <div class="flex-1">
                                <input type="file" id="edit-image" accept="image/*" class="form-input w-full px-4 py-3 rounded-lg text-white focus:outline-none">
                                <p class="text-sm text-gray-400 mt-1">Upload a new image for the event</p>
                            </div>
                        </div>
                    </div>
                </div>
                
                <div class="flex justify-between items-center pt-6 border-t border-gray-700">
                    <button type="button" id="delete-event-btn" class="btn-danger text-white px-6 py-3 rounded-lg transition-all">
                        <i class="fas fa-trash mr-2"></i>Delete Event
                    </button>
                    <div class="flex gap-4">
                        <button type="button" id="cancel-edit-btn" class="btn-secondary text-white px-6 py-3 rounded-lg transition-all">
                            <i class="fas fa-times mr-2"></i>Cancel
                        </button>
                        <button type="submit" class="btn-primary text-white font-bold px-8 py-3 rounded-lg transition-all">
                            <i class="fas fa-save mr-2"></i>Save Changes
                        </button>
                    </div>
                </div>
            </form>
        </div>
    </div>

    <!-- Convert to Recurring Modal -->
    <div id="convert-to-recurring-modal" class="fixed inset-0 modal-backdrop flex items-center justify-center p-4 z-50 hidden">
        <div class="modal-content rounded-2xl p-8 w-full max-w-2xl">
            <div class="flex justify-between items-center mb-6">
                <h3 class="font-anton text-3xl text-white">
                    <i class="fas fa-redo mr-3"></i>Convert to Recurring Event
                </h3>
                <button id="close-convert-modal-btn" class="text-gray-400 hover:text-white text-2xl transition-colors">
                    <i class="fas fa-times"></i>
                </button>
            </div>
            
            <form id="convert-to-recurring-form" class="space-y-6">
                <input type="hidden" id="convert-event-id" name="eventId">
                
                <div>
                    <label class="block text-sm font-medium text-gray-300 mb-2">
                        <i class="fas fa-redo mr-1"></i>Recurring Pattern
                    </label>
                    <select id="convert-recurring-pattern" name="recurringPattern" class="form-input w-full px-4 py-3 rounded-lg text-white focus:outline-none" required>
                        <option value="">Select a pattern...</option>
                        <option value="weekly">Weekly</option>
                        <option value="biweekly">Bi-weekly</option>
                        <option value="monthly">Monthly</option>
                        <option value="custom">Custom</option>
                    </select>
                </div>
                
                <div id="convert-custom-pattern" class="hidden">
                    <label class="block text-sm font-medium text-gray-300 mb-2">
                        <i class="fas fa-edit mr-1"></i>Custom Pattern Description
                    </label>
                    <textarea id="convert-custom-recurrence-desc" name="customRecurrenceDesc" rows="3" class="form-input w-full px-4 py-3 rounded-lg text-white focus:outline-none resize-none" placeholder="e.g., Every other Tuesday, First Friday of the month, etc."></textarea>
                </div>
                
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div>
                        <label class="block text-sm font-medium text-gray-300 mb-2">
                            <i class="fas fa-calendar mr-1"></i>Start Date
                        </label>
                        <input type="date" id="convert-recurring-start-date" name="recurringStartDate" class="form-input w-full px-4 py-3 rounded-lg text-white focus:outline-none">
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-300 mb-2">
                            <i class="fas fa-calendar mr-1"></i>End Date (Optional)
                        </label>
                        <input type="date" id="convert-recurring-end-date" name="recurringEndDate" class="form-input w-full px-4 py-3 rounded-lg text-white focus:outline-none">
                    </div>
                </div>
                
                <div>
                    <label class="block text-sm font-medium text-gray-300 mb-2">
                        <i class="fas fa-hashtag mr-1"></i>Maximum Instances (Optional)
                    </label>
                    <input type="number" id="convert-max-instances" name="maxInstances" min="1" max="52" class="form-input w-full px-4 py-3 rounded-lg text-white focus:outline-none" placeholder="e.g., 12 for 3 months of weekly events">
                </div>
                
                <div class="flex justify-end gap-4 pt-6 border-t border-gray-700">
                    <button type="button" id="cancel-convert-btn" class="btn-secondary text-white px-6 py-3 rounded-lg transition-all">
                        <i class="fas fa-times mr-2"></i>Cancel
                    </button>
                    <button type="submit" class="btn-primary text-white font-bold px-8 py-3 rounded-lg transition-all">
                        <i class="fas fa-redo mr-2"></i>Convert to Recurring
                    </button>
                </div>
            </form>
        </div>
    </div>

    <!-- Recurring Series Modal -->
    <div id="recurring-modal" class="fixed inset-0 modal-backdrop flex items-center justify-center p-4 z-50 hidden">
        <div class="modal-content rounded-2xl p-8 w-full max-w-5xl max-h-[90vh] overflow-y-auto">
            <div class="flex justify-between items-center mb-6">
                <h3 class="font-anton text-3xl text-white">
                    <i class="fas fa-redo mr-3"></i>Manage Recurring Series
                </h3>
                <button id="close-recurring-modal-btn" class="text-gray-400 hover:text-white text-2xl transition-colors">
                    <i class="fas fa-times"></i>
                </button>
            </div>
            
            <div id="recurring-modal-content">
                <!-- Content will be populated dynamically -->
            </div>
        </div>
    </div>


<script is:inline>
        // Mobile menu toggle
        document.querySelector('button.lg\\:hidden').addEventListener('click', function() {
            document.querySelector('aside').classList.toggle('hidden');
        });
    </script>
<script is:inline>
        // Force cache refresh
        if (performance.navigation.type === 1) {
            // Page was refreshed, clear any cached data
            localStorage.clear();
            sessionStorage.clear();
        }
    </script>
</AdminLayout>
